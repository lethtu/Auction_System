+
+
+/* Unified seller dashboard rounded template
+   The rounded background belongs to a plain StackPane wrapper, not ScrollPane.
+   JavaFX ScrollPane has a rectangular viewport which can paint over corner radii. */
+.seller-dashboard-surface {
+    -fx-background-color: linear-gradient(to bottom right, rgba(255, 251, 255, 0.94), rgba(254, 247, 255, 0.98));
+    -fx-background-radius: 30;
+    -fx-border-color: rgba(244, 221, 235, 0.98);
+    -fx-border-radius: 30;
+    -fx-border-width: 1;
+    -fx-effect: dropshadow(gaussian, rgba(224, 64, 160, 0.07), 18, 0.10, 0, 4);
+}
+
+.seller-dashboard-scroll {
+    -fx-background-color: transparent;
+    -fx-background: transparent;
+    -fx-border-color: transparent;
+    -fx-padding: 28;
+}
+
+.seller-dashboard-scroll > .viewport,
+.seller-dashboard-scroll > .corner,
+.seller-dashboard-scroll .viewport {
+    -fx-background-color: transparent;
+}
+
+.seller-dashboard-scroll .scroll-bar:vertical {
+    -fx-background-color: transparent;
+    -fx-padding: 3 0 3 1;
+}
+
+.seller-dashboard-body {
+    -fx-background-color: transparent;
+    -fx-padding: 0 0 6 0;
+}
+
+.seller-listings-card {
+    -fx-background-color: rgba(255, 255, 255, 0.96);
+    -fx-background-radius: 28;
+    -fx-border-color: rgba(220, 200, 224, 0.90);
+    -fx-border-radius: 28;
+    -fx-border-width: 1;
+    -fx-effect: dropshadow(gaussian, rgba(224, 64, 160, 0.10), 32, 0.16, 0, 10);
+}
+
+.seller-listings-header {
+    -fx-padding: 24;
+    -fx-border-color: rgba(220, 200, 224, 0.90);
+    -fx-border-width: 0 0 1 0;
+    -fx-background-color: rgba(251, 242, 251, 0.98);
+    -fx-background-radius: 28 28 0 0;
+}
+
+.seller-listings-footer {
+    -fx-padding: 16 24;
+    -fx-background-color: rgba(255, 255, 255, 0.96);
+    -fx-background-radius: 0 0 28 28;
+}
+
+.custom-table {
+    -fx-background-color: transparent;
+    -fx-background-radius: 0 0 26 26;
+    -fx-border-color: transparent;
+    -fx-border-radius: 0 0 26 26;
+    -fx-padding: 0 8 8 8;
+}
+
+.custom-table .virtual-flow,
+.custom-table .virtual-flow > .viewport,
+.custom-table .virtual-flow > .clipped-container {
+    -fx-background-color: transparent;
+    -fx-background-radius: 0 0 26 26;
+}
+
+.custom-table .column-header-background {
+    -fx-background-color: rgba(251, 242, 251, 0.96);
+    -fx-background-radius: 18 18 0 0;
+    -fx-border-color: rgba(220, 200, 224, 0.75);
+    -fx-border-width: 0 0 1 0;
+}
+
+.custom-table .filler {
+    -fx-background-color: rgba(251, 242, 251, 0.96);
+}
