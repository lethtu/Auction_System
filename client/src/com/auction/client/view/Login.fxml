<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" prefWidth="400.0" prefHeight="500.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController">
    <padding>
        <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
    </padding>

    <Label text="Đăng nhập Hệ thống Đấu giá">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
    </Label>

    <TextField fx:id="txtUsername" promptText="Tên đăng nhập / Email" prefHeight="35.0" />
    <PasswordField fx:id="txtPassword" promptText="Mật khẩu" prefHeight="35.0" />

    <HBox alignment="CENTER_RIGHT" prefWidth="200.0">
        <Hyperlink text="Quên mật khẩu?" onAction="#handleForgotPassword" style="-fx-text-fill: #dc3545;" />
    </HBox>

    <Button fx:id="btnLogin" onAction="#handleLogin" text="Đăng nhập" maxWidth="Infinity" prefHeight="40.0" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-weight: bold;" />

    <HBox alignment="CENTER" spacing="5.0">
        <Label text="Chưa có tài khoản?" />
        <Hyperlink fx:id="linkSignUp" onAction="#goToSignUp" text="Đăng ký ngay" />
    </HBox>
</VBox>