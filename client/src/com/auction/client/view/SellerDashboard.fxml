<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.SellerDashboardController"
      style="-fx-background-color: #f8fafc;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="SELLER DASHBOARD">
            <font>
                <Font size="24"/>
            </font>
        </Label>

        <Button text="Quay lại"
                onAction="#goBack"
                style="-fx-background-color: #334155; -fx-text-fill: white; -fx-background-radius: 10;"/>
    </HBox>

    <TabPane fx:id="sellerTabPane" tabClosingPolicy="UNAVAILABLE">
        <tabs>

            <Tab fx:id="tabMySessions" text="Phiên của tôi">
                <VBox spacing="12" style="-fx-background-color: white;">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>

                    <HBox spacing="10">
                        <Button text="Tất cả" onAction="#handleShowAllSessions"/>
                        <Button text="PENDING" onAction="#handleShowPendingSessions"/>
                        <Button text="ACTIVE" onAction="#handleShowActiveSessions"/>
                        <Button text="REJECTED" onAction="#handleShowRejectedSessions"/>
                    </HBox>

                    <ListView fx:id="mySessionsList" prefHeight="340"/>

                    <HBox spacing="10">
                        <Button text="Sửa phiên đã chọn"
                                onAction="#handleEditSelectedSession"
                                style="-fx-background-color: #3b82f6; -fx-text-fill: white;"/>

                        <Button text="Hủy phiên đã chọn"
                                onAction="#handleCancelSelectedSession"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white;"/>
                    </HBox>
                </VBox>
            </Tab>

            <Tab fx:id="tabCreateSession" text="Tạo phiên">
                <VBox spacing="10" style="-fx-background-color: white;">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>

                    <Label text="Tên sản phẩm"/>
                    <TextField fx:id="productNameField" promptText="Ví dụ: Laptop Dell XPS 13"/>

                    <Label text="Loại sản phẩm"/>
                    <ComboBox fx:id="productTypeCombo"/>

                    <Label text="Link ảnh"/>
                    <TextField fx:id="imageUrlField" promptText="https://..."/>

                    <Label text="Mô tả"/>
                    <TextArea fx:id="descriptionArea" prefRowCount="4"/>

                    <Label text="Giá khởi điểm"/>
                    <TextField fx:id="startingPriceField" promptText="15000000"/>

                    <Label text="Bước giá"/>
                    <TextField fx:id="stepPriceField" promptText="500000"/>

                    <Label text="Thời gian kết thúc"/>
                    <TextField fx:id="endTimeField" promptText="2026-12-31T20:00:00"/>

                    <Button fx:id="btnCreateOrUpdate"
                            text="Tạo phiên"
                            onAction="#handleCreateSession"
                            prefHeight="40"
                            style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-size: 14;"/>
                </VBox>
            </Tab>

            <Tab text="Thống kê">
                <VBox spacing="10" style="-fx-background-color: white;">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>

                    <Label text="Thống kê seller"/>
                    <TextArea fx:id="statsArea" editable="false" prefHeight="400"/>
                </VBox>
            </Tab>

        </tabs>
    </TabPane>
</VBox>