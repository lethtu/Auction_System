<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.NotificationCenterController" stylesheets="@styles.css" styleClass="notification-center-root" prefWidth="600.0" prefHeight="800.0">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="notification-header">
        <Label text="Notifications" styleClass="notification-title" />
        <Label fx:id="lblUnreadCount" text="0 unread" styleClass="notification-unread-pill" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Mark all as read" onAction="#handleMarkAllRead" styleClass="notification-link-button" />
    </HBox>

    <!-- Tabs/Filters -->
    <HBox spacing="10.0" styleClass="notification-filter-bar">
        <Button fx:id="tabAll" text="All" onAction="#filterAll" styleClass="notification-filter-tab" />
        <Button fx:id="tabUnread" text="Unread" onAction="#filterUnread" styleClass="notification-filter-tab" />
        <Button fx:id="tabAuction" text="Auction" onAction="#filterAuction" styleClass="notification-filter-tab" />
        <Button fx:id="tabSystem" text="System" onAction="#filterSystem" styleClass="notification-filter-tab" />
    </HBox>

    <!-- List -->
    <ScrollPane fitToWidth="true" styleClass="notification-scroll" VBox.vgrow="ALWAYS" hbarPolicy="NEVER">
        <VBox fx:id="listContainer" spacing="10.0" styleClass="notification-list">
            <!-- Notifications will be injected here -->
        </VBox>
    </ScrollPane>
</VBox>
