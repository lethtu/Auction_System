<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane stylesheets="@styles.css" styleClass="rounded-window-root" style="-fx-font-family: 'DM Sans';" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.MyBidsController">
<BorderPane prefWidth="1280.0" prefHeight="800.0" styleClass="rounded-window-content">

    <top>
        <fx:include source="Topbar.fxml" fx:id="topbar"/>
    </top>

    <left>
        <fx:include source="Sidebar.fxml" fx:id="sidebar">
            <BorderPane.margin>
                <Insets top="14.0" right="0.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
        </fx:include>
    </left>

    <center>
        <VBox spacing="20.0" styleClass="app-content-panel">
            <BorderPane.margin>
                <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 0 0 0 0;">
                <VBox spacing="4.0">
                    <Label text="My Bids" style="-fx-text-fill: -fx-accent; -fx-font-weight: 900; -fx-font-size: 32px;">
                        <font>
                            <Font name="System Bold" size="32.0" />
                        </font>
                    </Label>
                    <Label text="Track and manage your active auction participation." style="-fx-font-size: 15px; -fx-font-weight: 500; -fx-text-fill: #604868; -fx-font-weight: 700; -fx-font-size: 15px;" />
                </VBox>
            </HBox>
            
            <HBox spacing="12.0" style="-fx-padding: 0 0 0 0;">
                <Button fx:id="btnTabActive" text="Active Bids" onAction="#handleShowActive"
                        style="-fx-background-color: -fx-accent; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-padding: 10px 20px; -fx-cursor: hand; -fx-font-size: 14px;">
                    <graphic>
                        <Label text="&#128498;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 18px; -fx-text-fill: #ffffff; -fx-padding: 0 4px 0 0;" />
                    </graphic>
                </Button>
 
                <Button fx:id="btnTabWinning" text="Winning" onAction="#handleShowWinning"
                        style="-fx-background-color: #f8eef8; -fx-text-fill: #2e1a28; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-padding: 10px 20px; -fx-cursor: hand; -fx-font-size: 14px; -fx-graphic-text-gap: 8px;"
                        stylesheets="@styles.css">
                    <graphic>
                        <Label text="&#x1F3C6;" style="-fx-font-size: 24px; -fx-padding: 0 4px 0 0;" />
                    </graphic>
                </Button>
 
                <Button fx:id="btnTabOutbid" text="Outbid" onAction="#handleShowOutbid"
                        style="-fx-background-color: #f8eef8; -fx-text-fill: #2e1a28; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-padding: 10px 20px; -fx-cursor: hand; -fx-font-size: 14px;">
                    <graphic>
                        <Label text="&#x1F4C9;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 18px; -fx-text-fill: #ef4444; -fx-padding: 0 4px 0 0;" />
                    </graphic>
                </Button>
 
                <Button fx:id="btnTabEnded" text="Ended" onAction="#handleShowEnded"
                        style="-fx-background-color: #f8eef8; -fx-text-fill: #2e1a28; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-padding: 10px 20px; -fx-cursor: hand; -fx-font-size: 14px;">
                    <graphic>
                        <Label text="&#xe889;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 18px; -fx-text-fill: #7c52aa; -fx-padding: 0 4px 0 0;" />
                    </graphic>
                </Button>
            </HBox>
            
            <ScrollPane fx:id="scrollPane"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <StackPane alignment="TOP_CENTER" style="-fx-background-color: transparent;">
                    <FlowPane fx:id="productContainer"
                              alignment="TOP_LEFT"
                              hgap="25.0"
                              vgap="25.0"
                              style="-fx-padding: 10px 0 18px 0;">
                    </FlowPane>
                </StackPane>
            </ScrollPane>
            </VBox>
    </center>
    
</BorderPane>
</StackPane>
