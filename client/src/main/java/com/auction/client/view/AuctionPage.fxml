<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<StackPane stylesheets="@styles.css" styleClass="rounded-window-root" style="-fx-font-family: 'DM Sans';" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AuctionPageController">
    <BorderPane styleClass="rounded-window-content">
    <top>
        <fx:include source="Topbar.fxml" fx:id="topbar"/>
    </top>
    
    <left>
        <fx:include source="Sidebar.fxml" fx:id="sidebar">
            <BorderPane.margin>
                <Insets top="14.0" right="0.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
        </fx:include>
    </left>
    
    <center>
        <VBox spacing="20.0" styleClass="app-content-panel">
            <BorderPane.margin>
                <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="auction-page-scroll" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <content>
                                    <VBox spacing="24.0" style="-fx-padding: 12px 0;" maxWidth="Infinity" alignment="TOP_CENTER">
                                    <children>
                                        <GridPane fx:id="mainContentGrid" hgap="24.0" alignment="TOP_CENTER" maxWidth="1400.0">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="60.0" />
                                                <ColumnConstraints percentWidth="40.0" />
                                            </columnConstraints>
                                            <children>
                                                <!-- Left Side: Product Showcase (60%) -->
                                                <VBox spacing="24.0" GridPane.columnIndex="0">
                                                    <children>
                                                        <!-- Product Card -->
                                                        <VBox spacing="24.0" style="-fx-background-color: -app-card; -fx-padding: 24; -fx-background-radius: 32; -fx-effect: dropshadow(three-pass-box, -app-accent-opacity-10, 20, 0, 0, 10); -fx-border-color: -app-border; -fx-border-width: 1; -fx-border-radius: 32;">
                                                            <children>
                                                                <StackPane alignment="TOP_LEFT">
                                                                    <children>
                                                                        <StackPane fx:id="productMediaFrame" alignment="CENTER" minWidth="0.0" prefWidth="550.0" maxWidth="Infinity" minHeight="400.0" prefHeight="400.0" maxHeight="400.0" style="-fx-background-color: -app-surface-2; -fx-background-radius: 32; -fx-overflow: hidden;">
                                                                            <children>
                                                                                <ImageView fx:id="productImageView" fitHeight="400.0" fitWidth="550.0" preserveRatio="true" />
                                                                                <StackPane fx:id="model3DContainer" visible="false" managed="false" alignment="CENTER" maxWidth="Infinity" maxHeight="Infinity" styleClass="model-3d-overlay" />
                                                                            </children>
                                                                        </StackPane>
                                                                        
                                                                        <HBox pickOnBounds="false" maxWidth="-Infinity" maxHeight="-Infinity" spacing="8.0" style="-fx-padding: 12;" StackPane.alignment="TOP_LEFT">
                                                                            <children>
                                                                                <HBox alignment="CENTER" spacing="6.0" style="-fx-background-color: -fx-accent; -fx-padding: 4 12; -fx-background-radius: 999; -fx-effect: dropshadow(three-pass-box, -app-accent-opacity-30, 10, 0, 0, 4);">
                                                                                    <children>
                                                                                        <Label text="&#xe061;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 10px; -fx-text-fill: white;" />
                                                                                        <Label text="LIVE NOW" style="-fx-font-family: 'DM Sans'; -fx-font-size: 12px; -fx-font-weight: 900; -fx-text-fill: white;" />
                                                                                    </children>
                                                                                </HBox>
                                                                            </children>
                                                                        </HBox>

                                                                        <Button fx:id="btnToggle3D" onAction="#handleToggle3D" visible="false" managed="false" StackPane.alignment="TOP_RIGHT" style="-fx-background-color: -app-card; -fx-text-fill: -fx-accent; -fx-background-radius: 999; -fx-padding: 6 14; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, -app-accent-opacity-30, 10, 0, 0, 4); -fx-border-color: -fx-accent; -fx-border-width: 1.5; -fx-border-radius: 999; -fx-translate-x: -12; -fx-translate-y: 12;">
                                                                            <graphic>
                                                                                <HBox alignment="CENTER" spacing="6.0">
                                                                                    <children>
                                                                                        <Label text="&#xe0b4;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 14px; -fx-text-fill: -fx-accent;" />
                                                                                        <Label text="3D VIEW" style="-fx-font-family: 'DM Sans'; -fx-font-size: 12px; -fx-font-weight: 900; -fx-text-fill: -fx-accent;" />
                                                                                    </children>
                                                                                </HBox>
                                                                            </graphic>
                                                                        </Button>
                                                                    </children>
                                                                </StackPane>
                                                                
                                                                <HBox alignment="TOP_LEFT" spacing="20.0">
                                                                    <children>
                                                                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                                                            <children>
                                                                                <Label fx:id="productNameLabel" text="Loading..." style="-fx-font-family: 'DM Sans'; -fx-font-size: 30px; -fx-font-weight: 900; " wrapText="true" />
                                                                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                                                                    <children>
<Label text="Real-time bidding • Active auction" style="-fx-font-family: 'DM Sans'; -fx-font-size: 14px; " />
                                                                                    </children>
                                                                                </HBox>
                                                                            </children>
                                                                        </VBox>
                                                                        <VBox alignment="TOP_RIGHT" spacing="0.0">
                                                                            <children>
                                                                                <Label fx:id="endingInTitleLabel" text="ENDING IN" style="-fx-font-family: 'DM Sans'; -fx-font-size: 14px; -fx-font-weight: 900; -fx-text-fill: #7c52aa;" />
                                                                                <Label fx:id="remainingTimeLabel" text="00:00:00" style="-fx-font-family: 'DM Sans'; -fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: -fx-accent;" />
                                                                            </children>
                                                                        </VBox>
                                                                    </children>
                                                                </HBox>
                                                                
                                                                <GridPane hgap="16.0" vgap="0.0">
                                                                    <columnConstraints>
                                                                        <ColumnConstraints percentWidth="33.3" />
                                                                        <ColumnConstraints percentWidth="33.3" />
                                                                        <ColumnConstraints percentWidth="33.3" />
                                                                    </columnConstraints>
                                                                    <children>
                                                                        <VBox spacing="4.0" styleClass="auction-stat-card" GridPane.columnIndex="0">
                                                                            <children>
                                                                                <Label text="&#xe889;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #7c52aa;" />
                                                                                <Label text="TOTAL BIDS" style="-fx-font-family: 'DM Sans'; -fx-font-size: 12px; -fx-font-weight: 900; -fx-text-fill: -app-text-muted; -fx-padding: 8 0 0 0;" />
                                                                                <Label fx:id="totalBidsLabel" text="0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: -app-text;" />
                                                                            </children>
                                                                        </VBox>
                                                                        <VBox spacing="4.0" styleClass="auction-stat-card" GridPane.columnIndex="1">
                                                                            <children>
                                                                                <Label text="&#xe7ff;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #0096cc;" />
                                                                                <Label text="WATCHING" style="-fx-font-family: 'DM Sans'; -fx-font-size: 12px; -fx-font-weight: 900; -fx-text-fill: -app-text-muted; -fx-padding: 8 0 0 0;" />
                                                                                <Label fx:id="watchingLabel" text="0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: -app-text;" />
                                                                            </children>
                                                                        </VBox>
                                                                        <VBox spacing="4.0" styleClass="auction-stat-card" GridPane.columnIndex="2">
                                                                            <children>
                                                                                <Label text="&#xe8e5;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: -fx-accent;" />
                                                                                <Label fx:id="startPriceTitleLabel" text="START PRICE" style="-fx-font-family: 'DM Sans'; -fx-font-size: 12px; -fx-font-weight: 900; -fx-text-fill: -app-text-muted; -fx-padding: 8 0 0 0;" />
                                                                                <Label fx:id="startPriceLabel" text="₫ 0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: -app-text;" />
                                                                            </children>
                                                                        </VBox>
                                                                    </children>
                                                                </GridPane>
                                                                
                                                                <VBox spacing="12.0">
                                                                    <children>
                                                                        <Label text="Item Description" style="-fx-font-family: 'DM Sans'; -fx-font-size: 18px; -fx-font-weight: 900; " />
                                                                        <Label fx:id="itemDescriptionLabel" text="No product description available." wrapText="true" style="-fx-font-family: 'DM Sans'; -fx-font-size: 16px;  -fx-line-spacing: 6;" />
                                                                    </children>
                                                                </VBox>
                                                                

                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </VBox>
                                                
                                                <!-- Right Side: Bidding Panel (40%) -->
                                                <VBox spacing="24.0" GridPane.columnIndex="1">
                                                    <children>
                                                        <VBox spacing="24.0" style="-fx-background-color: -app-card; -fx-padding: 24; -fx-background-radius: 32; -fx-effect: dropshadow(three-pass-box, -app-accent-opacity-20, 24, 0, 0, 8); -fx-border-color: -fx-accent; -fx-border-width: 2; -fx-border-radius: 32;">
                                                            <children>
                                                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                                    <children>
                                                                        <Label fx:id="highestBidTitleLabel" text="CURRENT HIGHEST BID" style="-fx-font-family: 'DM Sans'; -fx-font-size: 14px; -fx-font-weight: 900; " />
                                                                        <Region HBox.hgrow="ALWAYS" />
                                                                        <Label fx:id="reserveStatusLabel" text="" style="-fx-font-family: 'DM Sans'; -fx-font-size: 12px; -fx-font-weight: 900; -fx-text-fill: -fx-accent;" />
                                                                    </children>
                                                                </HBox>
                                                                <HBox alignment="BASELINE_LEFT" spacing="8.0">
                                                                    <children>
                                                                        <Label fx:id="currentPriceLabel" text="₫ 0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 48px; -fx-font-weight: 900; " />
                                                                    </children>
                                                                </HBox>
                                                                <Label fx:id="highestBidderLabel" text="No bids yet" style="-fx-font-family: 'DM Sans'; -fx-font-size: 12px; -fx-font-weight: 800; " />
                                                            </children>
                                                        </VBox>
                                                        
                                                        <VBox spacing="24.0" style="-fx-background-color: -app-card; -fx-padding: 24; -fx-background-radius: 32; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: -app-border; -fx-border-width: 1; -fx-border-radius: 32;">
                                                            <children>
                                                                <VBox spacing="8.0">
                                                                    <children>
                                                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                                            <children>
                                                                                <Label fx:id="bidAmountTitleLabel" text="Your Bid Amount" style="-fx-font-family: 'DM Sans'; -fx-font-size: 14px; -fx-font-weight: 900; " />
                                                                                <Region HBox.hgrow="ALWAYS" />
                                                                                <Label fx:id="minIncrementLabel" text="Min increment ₫ 0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 12px; -fx-font-weight: 900; -fx-text-fill: -fx-accent;" />
                                                                            </children>
                                                                        </HBox>
                                                                        <HBox fx:id="availableBalanceCard" alignment="CENTER_LEFT" spacing="10.0" styleClass="available-balance-card">
                                                                            <children>
                                                                                <StackPane minWidth="34.0" prefWidth="34.0" maxWidth="34.0" minHeight="34.0" prefHeight="34.0" maxHeight="34.0" styleClass="available-balance-icon-wrap">
                                                                                    <children>
                                                                                        <Label text="&#xe850;" styleClass="available-balance-icon" />
                                                                                    </children>
                                                                                </StackPane>
                                                                                <VBox spacing="1.0" HBox.hgrow="ALWAYS">
                                                                                    <children>
                                                                                        <Label text="Available Balance" styleClass="available-balance-label" />
                                                                                        <Label fx:id="availableBalanceValue" text="--" styleClass="available-balance-value" />
                                                                                    </children>
                                                                                </VBox>
                                                                                <Button fx:id="availableBalanceToggle" text="&#xe8f4;" minWidth="34.0" prefWidth="34.0" maxWidth="34.0" minHeight="34.0" prefHeight="34.0" maxHeight="34.0" styleClass="balance-eye-button" />
                                                                            </children>
                                                                        </HBox>
                                                                        <StackPane alignment="CENTER_LEFT">
                                                                            <children>
                                                                                <TextField fx:id="bidAmountField" style="-fx-background-color: -app-input-bg; -fx-background-radius: 999; -fx-text-fill: -app-input-text; -fx-border-color: -app-border; -fx-border-width: 2; -fx-border-radius: 999; -fx-padding: 16 16 16 48; -fx-font-family: 'DM Sans'; -fx-font-size: 24px; -fx-font-weight: 900;" />
                                                                                <Label text="₫" style="-fx-font-family: 'DM Sans'; -fx-font-size: 24px; -fx-font-weight: 900;  -fx-padding: 0 0 0 20;" />
                                                                            </children>
                                                                        </StackPane>
                                                                    </children>
                                                                </VBox>
                                                                <HBox fx:id="quickBidBox" spacing="8.0">
                                                                    <children>
                                                                        <Button fx:id="btnQuickBidOne" maxWidth="Infinity" HBox.hgrow="ALWAYS" text="+1x" onAction="#handleQuickBidOne" style="-fx-background-color: -app-accent-opacity-08; -fx-text-fill: -fx-accent; -fx-border-color: -fx-accent; -fx-border-width: 1; -fx-border-radius: 999; -fx-background-radius: 999; -fx-padding: 8 12; -fx-font-family: 'DM Sans'; -fx-font-size: 12px; -fx-font-weight: 900; -fx-cursor: hand;" />
                                                                        <Button fx:id="btnQuickBidTwo" maxWidth="Infinity" HBox.hgrow="ALWAYS" text="+2x" onAction="#handleQuickBidTwo" style="-fx-background-color: -app-accent-opacity-08; -fx-text-fill: -fx-accent; -fx-border-color: -fx-accent; -fx-border-width: 1; -fx-border-radius: 999; -fx-background-radius: 999; -fx-padding: 8 12; -fx-font-family: 'DM Sans'; -fx-font-size: 12px; -fx-font-weight: 900; -fx-cursor: hand;" />
                                                                        <Button fx:id="btnQuickBidFive" maxWidth="Infinity" HBox.hgrow="ALWAYS" text="+5x" onAction="#handleQuickBidFive" style="-fx-background-color: -app-accent-opacity-08; -fx-text-fill: -fx-accent; -fx-border-color: -fx-accent; -fx-border-width: 1; -fx-border-radius: 999; -fx-background-radius: 999; -fx-padding: 8 12; -fx-font-family: 'DM Sans'; -fx-font-size: 12px; -fx-font-weight: 900; -fx-cursor: hand;" />
                                                                    </children>
                                                                </HBox>
                                                                <Button fx:id="placeBidBtn" maxWidth="Infinity" onAction="#handlePlaceBid" text="PLACE BID NOW" style="-fx-background-color: -fx-accent; -fx-text-fill: white; -fx-padding: 16; -fx-background-radius: 999; -fx-font-family: 'DM Sans'; -fx-font-size: 18px; -fx-font-weight: 900; -fx-cursor: hand;" />
                                                                <Button fx:id="btnAutoBid" maxWidth="Infinity" onAction="#handleAutoBidConfig" text="⚡ Configure Auto-bid" style="-fx-background-color: transparent; -fx-text-fill: #7c52aa; -fx-border-color: #7c52aa; -fx-border-width: 2; -fx-border-radius: 999; -fx-background-radius: 999; -fx-padding: 12; -fx-font-family: 'DM Sans'; -fx-font-size: 14px; -fx-font-weight: 900; -fx-cursor: hand;" />
                                                                
                                                                <Label fx:id="messageLabel" alignment="CENTER" maxWidth="Infinity" style="-fx-font-family: 'DM Sans'; -fx-font-size: 12px; -fx-text-fill: #e53e3e;" />
                                                            </children>
                                                        </VBox>
                                                                                                 <VBox VBox.vgrow="ALWAYS" spacing="0" style="-fx-background-color: -app-card; -fx-padding: 0; -fx-background-radius: 32; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-border-color: -app-border; -fx-border-width: 1; -fx-border-radius: 32;">
                                                            <children>
                                                                <!-- Chart Header -->
                                                                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 20 24 12 24;">
                                                                    <children>
                                                                        <StackPane minWidth="32" maxWidth="32" minHeight="32" maxHeight="32" style="-fx-background-color: linear-gradient(to bottom right, -fx-accent, #a855f7); -fx-background-radius: 10;">
                                                                            <Label text="&#xe6e1;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 16px; -fx-text-fill: white;" />
                                                                        </StackPane>
                                                                        <VBox spacing="0">
                                                                            <Label text="BID TRAJECTORY" style="-fx-font-family: 'DM Sans'; -fx-font-size: 13px; -fx-font-weight: 900; " />
                                                                            <Label text="Price movement over recent bids" style="-fx-font-family: 'DM Sans'; -fx-font-size: 10px; -fx-text-fill: -app-text-muted;" />
                                                                        </VBox>
                                                                    </children>
                                                                </HBox>
 
                                                                <!-- Chart Area -->
                                                                <StackPane prefHeight="170" style="-fx-background-color: linear-gradient(to bottom, -app-card, -app-surface-2); -fx-background-radius: 0; -fx-padding: 8 16;">
                                                                    <VBox fx:id="chartContainer" alignment="CENTER" />
                                                                </StackPane>
 
                                                                <!-- Separator -->
                                                                <Separator style="-fx-background-color: transparent; -fx-border-color: -app-border; -fx-border-width: 1 0 0 0;" />

                                                                <!-- Recent Activity Header -->
                                                                <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 14 24 6 24;">
                                                                    <children>
                                                                        <Label text="&#xe889;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 14px; -fx-text-fill: #a855f7;" />
                                                                        <Label text="RECENT ACTIVITY" style="-fx-font-family: 'DM Sans'; -fx-font-size: 11px; -fx-font-weight: 900; -fx-text-fill: #7c52aa; -fx-letter-spacing: 1;" />
                                                                    </children>
                                                                </HBox>

                                                                <!-- Bid History List (scrollable) -->
                                                                <ScrollPane fitToWidth="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER" maxHeight="300" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent; -fx-padding: 0;">
                                                                    <VBox fx:id="bidHistoryContainer" spacing="4" style="-fx-padding: 4 10 20 10;" />
                                                                </ScrollPane>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </GridPane>
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
        </VBox>
    </center>
</BorderPane>
</StackPane>
