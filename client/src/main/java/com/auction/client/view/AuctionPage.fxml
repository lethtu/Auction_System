                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <Label text="&#xe887;" minWidth="24" alignment="CENTER" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #604868;" />
                                        <Label fx:id="supportText" text="Support" visible="false" managed="false" style="-fx-font-family: 'DM Sans'; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #604868;" />
                                    </children>
                                </HBox>
                            </graphic>
                        </Button>
                        
                        <Region VBox.vgrow="ALWAYS" />
                        
                        <!-- Start Selling -->
                        <Button maxWidth="Infinity" alignment="CENTER_LEFT" onAction="#handleStartSelling" style="-fx-background-color: #e040a0; -fx-padding: 12; -fx-background-radius: 20; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.3), 16, 0, 0, 4);">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <Label text="&#xe145;" minWidth="24" alignment="CENTER" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: white;" />
                                        <Label fx:id="startSellingText" text="Start Selling" visible="false" managed="false" style="-fx-font-family: 'DM Sans'; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;" />
                                    </children>
                                </HBox>
                            </graphic>
                        </Button>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>