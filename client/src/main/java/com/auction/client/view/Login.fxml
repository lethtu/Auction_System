<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController" styleClass="auth-root" stylesheets="@../css/auth-theme.css">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <HBox styleClass="auth-shell" maxWidth="1000.0" maxHeight="650.0">
        <!-- Cột trái: Branding -->
        <VBox styleClass="auth-brand-panel" HBox.hgrow="ALWAYS" prefWidth="500.0" alignment="CENTER" spacing="30.0">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
            </padding>
            <VBox alignment="CENTER_LEFT" spacing="10.0" VBox.vgrow="ALWAYS">
                <Label text="BidPop" styleClass="auth-brand-title"/>
                <Label text="The most vibrant marketplace for digital collectibles and rare finds." styleClass="auth-brand-subtitle"/>
            </VBox>
            <VBox styleClass="auth-card-overlay" spacing="15.0" style="-fx-padding: 20.0;" VBox.vgrow="NEVER">
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <Label text="gavel" styleClass="material-icon" style="-fx-text-fill: #e040a0; -fx-background-color: #ffffff; -fx-background-radius: 20; -fx-padding: 10;" mouseTransparent="true"/>
                    <VBox>
                        <Label fx:id="lblLiveAuctions" text="Live Auctions Now" style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-size: 16px; -fx-font-family: 'DM Sans';"/>
                        <Label fx:id="lblActiveBidders" text="Join 12,000+ active bidders" style="-fx-text-fill: #ffd6ee; -fx-font-size: 12px; -fx-font-family: 'DM Sans';"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>

        <!-- Cột phải: Form -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS" prefWidth="500.0">
            <padding>
                <Insets bottom="40.0" left="60.0" right="60.0" top="40.0"/>
            </padding>
            <VBox maxWidth="350.0" spacing="25.0" VBox.vgrow="ALWAYS" alignment="CENTER">
                
                <VBox spacing="5.0" maxWidth="Infinity">
                    <Label text="Welcome Back" styleClass="auth-title"/>
                    <Label text="Ready to place your next winning bid?" styleClass="auth-subtitle"/>
                </VBox>

                <!-- Form Fields -->
                <VBox spacing="20.0" maxWidth="Infinity">
                    <VBox spacing="5.0">
                        <Label text="Username / Email" styleClass="auth-input-label"/>
                        <TextField fx:id="txtUsername" promptText="alex@example.com" styleClass="auth-input"/>
                    </VBox>

                    <VBox spacing="5.0">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Password" styleClass="auth-input-label" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            <Hyperlink text="Forgot?" onAction="#handleForgotPassword" styleClass="auth-secondary-link" style="-fx-font-size: 12px;"/>
                        </HBox>
                        <PasswordField fx:id="txtPassword" promptText="••••••••" styleClass="auth-input"/>
                    </VBox>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10.0" maxWidth="Infinity">
                    <CheckBox text="Keep me signed in on this device" style="-fx-font-family: 'DM Sans'; -fx-text-fill: #604868; -fx-font-size: 13px;"/>
                </HBox>

                <Button fx:id="btnLogin" text="Enter Marketplace" onAction="#handleLogin" maxWidth="Infinity" prefHeight="50.0" styleClass="auth-primary-button"/>

                <VBox spacing="20.0" alignment="CENTER" maxWidth="Infinity">
                    <HBox alignment="CENTER" spacing="5.0">
                        <Label text="Don't have an account?" style="-fx-font-family: 'DM Sans'; -fx-text-fill: #604868; -fx-font-weight: 500;"/>
                        <Hyperlink fx:id="linkSignUp" text="Create Profile" onAction="#goToSignUp" styleClass="auth-secondary-link"/>
                    </HBox>

                    <HBox spacing="10.0" alignment="CENTER">
                        <Button fx:id="btnGoogle" text=" Google (Soon)" styleClass="auth-social-button" prefWidth="120.0" prefHeight="40.0" onAction="#handleGoogleLogin"/>
                        <Button fx:id="btnFacebook" text=" Facebook (Soon)" styleClass="auth-social-button" prefWidth="120.0" prefHeight="40.0" onAction="#handleFacebookLogin"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </HBox>
</StackPane>