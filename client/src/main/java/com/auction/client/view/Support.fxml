<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane stylesheets="@styles.css" styleClass="rounded-window-root" style="-fx-font-family: 'DM Sans';" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.SupportController">
<BorderPane prefWidth="1280.0" prefHeight="800.0" styleClass="rounded-window-content">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0.0" styleClass="app-topbar">
            <StackPane prefWidth="70.0" minWidth="70.0" maxWidth="70.0">
                <Button fx:id="btnHamburger" onAction="#handleToggleSidebar" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;">
                    <graphic>
                        <Label text="&#xe5d2;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; " />
                    </graphic>
                </Button>
            </StackPane>
            <Label text="HY Auction" textFill="#e040a0" onMouseClicked="#handleGoToDashboard" style="-fx-cursor: hand; -fx-font-weight: bold;">
                <font>
                    <Font name="System Bold" size="28.0" />
                </font>
            </Label>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox alignment="CENTER_LEFT" prefWidth="500.0" prefHeight="40.0" style="  -fx-border-width: 2px; -fx-border-radius: 999; -fx-background-radius: 999; -fx-padding: 0 16px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.05), 10, 0, 0, 2);">
                <Label text="&#xe8b6;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #e040a0;" translateY="0.0" />
                <TextField fx:id="txtSearch" promptText="Search items, categories, or auctions..." HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-padding: 0 0 0 8px; -fx-prompt-text-fill: #907898;  -fx-font-size: 14px;" />
            </HBox>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox spacing="10.0" alignment="CENTER_RIGHT" minHeight="52.0" prefHeight="52.0" maxHeight="52.0" style="-fx-padding: 0;">
                <StackPane alignment="CENTER" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0">
                    <Button fx:id="btnNotificationBell" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center;">
                        <graphic>
                            <Label text="&#xe7f4;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; " />
                        </graphic>
                    </Button>
                    <Label fx:id="notificationBadge" text="0" visible="false" managed="false" style="-fx-background-color: #e040a0; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 1 5; -fx-background-radius: 10; -fx-translate-x: 12; -fx-translate-y: -12;" />
                </StackPane>
                <Button fx:id="btnSettings" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center;">
                    <graphic>
                        <Label text="&#xe8b8;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; " />
                    </graphic>
                </Button>
                <MenuButton fx:id="userMenuButton" id="profile-menu" minWidth="58.0" prefWidth="58.0" maxWidth="58.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center; -fx-background-insets: 0;">
                    <graphic>
                        <StackPane fx:id="topBarAvatarPane" minWidth="44" maxWidth="44" minHeight="44" maxHeight="44" prefWidth="44" prefHeight="44" style="-fx-background-color: #1a1a3a; -fx-background-radius: 22px;">
                            <Label text="&#xe7fd;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: white;" />
                        </StackPane>
                    </graphic>
                </MenuButton>
                <HBox alignment="CENTER" spacing="6" style="-fx-padding: 0 0 0 10;">
                    <Button onAction="#handleMinimize" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4;">
                        <graphic>
                            <Label text="−" style="-fx-font-family: 'DM Sans'; -fx-font-size: 16px; -fx-font-weight: 900; " />
                        </graphic>
                    </Button>
                    <Button onAction="#handleMaximize" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4;">
                        <graphic>
                            <Label text="□" style="-fx-font-family: 'DM Sans'; -fx-font-size: 16px; -fx-font-weight: 900; " />
                        </graphic>
                    </Button>
                    <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4;">
                        <graphic>
                            <Label text="×" style="-fx-font-family: 'DM Sans'; -fx-font-size: 16px; -fx-font-weight: 900; " />
                        </graphic>
                    </Button>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <left>
        <fx:include source="Sidebar.fxml" fx:id="sidebar">
            <BorderPane.margin>
                <Insets top="14.0" right="0.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
        </fx:include>
    </left>

    <center>
        <VBox spacing="20.0" styleClass="app-content-panel">
            <BorderPane.margin>
                <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
            <!-- Header Title -->
            <VBox spacing="10.0" style="-fx-padding: 0 0 10px 0;">
                <Label text="HELP &amp; SUPPORT CENTER" style="-fx-font-size: 32px; -fx-font-weight: bold; " />
                <Label text="We are always ready to answer your questions and support you during the auction process." style="-fx-font-size: 15px; " />
            </VBox>
            
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="35.0" style="-fx-padding: 10px 0px;">

                <!-- 2-Column Grid Area -->
                <HBox spacing="40.0" alignment="TOP_LEFT">
                    <!-- Column 1: Contact Form (Left) -->
                    <VBox spacing="24.0" prefWidth="480.0" minWidth="400.0" HBox.hgrow="ALWAYS" style=" -fx-padding: 30px; -fx-background-radius: 24px;  -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.06), 20, 0, 0, 6);">
                        <Label text="SUBMIT SUPPORT REQUEST" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e040a0;" />
                        
                        <VBox spacing="8.0">
                            <Label text="Contact Email *" style="-fx-font-size: 13px; -fx-font-weight: bold; " />
                            <TextField fx:id="txtEmail" promptText="Enter your email..." style="  -fx-border-width: 2px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 12px 16px;  -fx-font-size: 14px;" />
                        </VBox>

                        <VBox spacing="8.0">
                            <Label text="Subject *" style="-fx-font-size: 13px; -fx-font-weight: bold; " />
                            <TextField fx:id="txtSubject" promptText="Enter support topic..." style="  -fx-border-width: 2px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 12px 16px;  -fx-font-size: 14px;" />
                        </VBox>

                        <VBox spacing="8.0">
                            <Label text="Message Content *" style="-fx-font-size: 13px; -fx-font-weight: bold; " />
                            <TextArea fx:id="txtAreaMessage" prefHeight="160.0" wrapText="true" promptText="Enter details of your support request..." style="  -fx-border-width: 2px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 8px;  -fx-font-size: 14px;" />
                        </VBox>

                        <Label fx:id="lblMessageStatus" text="" visible="false" managed="false" style="-fx-font-size: 14px; -fx-font-weight: bold;" />

                        <Button fx:id="btnSendSupport" onAction="#handleSendSupport" text="Send Message" maxWidth="Infinity" prefHeight="48.0" style="-fx-background-color: #e040a0; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 24px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.3), 12, 0, 0, 4);">
                            <graphic>
                                <Label text="&#xe163;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: white;" translateY="2.0" />
                            </graphic>
                        </Button>
                    </VBox>

                    <!-- Column 2: FAQ & Contacts (Right) -->
                    <VBox spacing="24.0" HBox.hgrow="ALWAYS">
                        <!-- FAQ Header -->
                        <VBox spacing="16.0" style=" -fx-padding: 30px; -fx-background-radius: 24px;  -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.06), 20, 0, 0, 6);">
                            <Label text="FREQUENTLY ASKED QUESTIONS (FAQ)" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e040a0;" />
                            
                            <!-- Question 1 -->
                            <VBox spacing="6.0" style=" -fx-border-width: 0 0 1px 0; -fx-padding: 0 0 12px 0;">
                                <Label text="How do I bid on a product?" style="-fx-font-size: 15px; -fx-font-weight: bold; " />
                                <Label text="Simply find the product you want, enter the auction room and place a valid bid higher than the current price plus the minimum step price." wrapText="true" style="-fx-font-size: 13.5px; " />
                            </VBox>

                            <!-- Question 2 -->
                            <VBox spacing="6.0" style=" -fx-border-width: 0 0 1px 0; -fx-padding: 0 0 12px 0;">
                                <Label text="How do I deposit funds into my account?" style="-fx-font-size: 15px; -fx-font-weight: bold; " />
                                <Label text="Click the account icon in the top navigation bar, select 'Deposit' and make a transfer following the displayed instructions." wrapText="true" style="-fx-font-size: 13.5px; " />
                            </VBox>

                            <!-- Question 3 -->
                            <VBox spacing="6.0" style="-fx-padding: 0 0 4px 0;">
                                <Label text="How can I become a Seller?" style="-fx-font-size: 15px; -fx-font-weight: bold; " />
                                <Label text="Click the 'Start Selling' button on the left sidebar (if you are not a Seller yet), read the terms carefully and click 'Upgrade Now'." wrapText="true" style="-fx-font-size: 13.5px; " />
                            </VBox>
                        </VBox>

                        <!-- Contact Channels Card -->
                        <VBox spacing="16.0" style=" -fx-padding: 30px; -fx-background-radius: 24px;  -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.06), 20, 0, 0, 6);">
                            <Label text="DIRECT CONTACT CHANNELS" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e040a0;" />
                            
                            <HBox spacing="12.0" alignment="CENTER_LEFT">
                                <Label text="&#xe0b0;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #e040a0;" />
                                <Label text="Support hotline: 1900 6868 (8:00 - 22:00)" style="-fx-font-size: 14px;  -fx-font-weight: bold;" />
                            </HBox>

                            <HBox spacing="12.0" alignment="CENTER_LEFT">
                                <Label text="&#xe158;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #e040a0;" />
                                <Label text="Email: lethanhtungbot01@gmail.com" style="-fx-font-size: 14px;  -fx-font-weight: bold;" />
                            </HBox>

                            <HBox spacing="12.0" alignment="CENTER_LEFT">
                                <Label text="&#xe0c8;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #e040a0;" />
                                <Label text="Address: Hanoi" wrapText="true" style="-fx-font-size: 14px;  -fx-font-weight: bold;" />
                            </HBox>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
        </VBox>
    </center>
</BorderPane>
</StackPane>
