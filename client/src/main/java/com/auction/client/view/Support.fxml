<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane stylesheets="@styles.css" styleClass="rounded-window-root" style="-fx-font-family: 'DM Sans';" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.SupportController">
<BorderPane prefWidth="1280.0" prefHeight="800.0" styleClass="rounded-window-content">

    <top>
        <fx:include source="Topbar.fxml" fx:id="topbar"/>
    </top>

    <left>
        <fx:include source="Sidebar.fxml" fx:id="sidebar">
            <BorderPane.margin>
                <Insets top="14.0" right="0.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
        </fx:include>
    </left>

    <center>
        <VBox spacing="20.0" styleClass="app-content-panel">
            <BorderPane.margin>
                <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>

            <HBox alignment="CENTER_LEFT" spacing="18.0" style="-fx-padding: 0 2px 8px 2px;">
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label id="supportPageTitle" text="Support Center" />
                    <Label id="supportPageSubtitle" text="Ask for help, check common auction questions, or contact the team directly." wrapText="true" />
                </VBox>
                <HBox alignment="CENTER" spacing="8.0" styleClass="support-status-pill">
                    <Label text="&#xe86c;" styleClass="support-pill-icon" />
                    <Label text="Online support" styleClass="support-pill-text" />
                </HBox>
            </HBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="support-scroll-pane" VBox.vgrow="ALWAYS">
                <VBox spacing="22.0" style="-fx-padding: 8px 14px 24px 14px;">

                    <HBox spacing="22.0" alignment="TOP_LEFT">
                        <VBox spacing="18.0" prefWidth="500.0" minWidth="430.0" HBox.hgrow="ALWAYS" styleClass="support-card support-form-card">
                            <HBox spacing="12.0" alignment="CENTER_LEFT">
                                <StackPane styleClass="support-card-icon-box">
                                    <Label text="&#xe0be;" styleClass="support-card-icon" />
                                </StackPane>
                                <VBox spacing="3.0">
                                    <Label text="Submit support request" styleClass="support-card-title" />
                                    <Label text="Send us the issue detail so the team can check it faster." styleClass="support-card-subtitle" wrapText="true" />
                                </VBox>
                            </HBox>

                            <VBox spacing="8.0">
                                <Label text="Contact Email *" styleClass="support-field-label" />
                                <TextField fx:id="txtEmail" promptText="Enter your email..." styleClass="support-input" />
                            </VBox>

                            <VBox spacing="8.0">
                                <Label text="Subject *" styleClass="support-field-label" />
                                <TextField fx:id="txtSubject" promptText="Enter support topic..." styleClass="support-input" />
                            </VBox>

                            <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                                <Label text="Message Content *" styleClass="support-field-label" />
                                <TextArea fx:id="txtAreaMessage" prefHeight="170.0" wrapText="true" promptText="Describe what happened, which screen you used, and what you expected..." styleClass="support-input support-message-area" />
                            </VBox>

                            <Label fx:id="lblMessageStatus" text="" visible="false" managed="false" wrapText="true" maxWidth="Infinity" styleClass="support-message-status" />

                            <Button fx:id="btnSendSupport" onAction="#handleSendSupport" text="Send Message" maxWidth="Infinity" prefHeight="50.0" styleClass="support-primary-btn">
                                <graphic>
                                    <Label text="&#xe163;" styleClass="support-primary-btn-icon" />
                                </graphic>
                            </Button>
                        </VBox>

                        <VBox spacing="18.0" prefWidth="500.0" minWidth="430.0" HBox.hgrow="ALWAYS">
                            <HBox spacing="14.0">
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS" styleClass="support-mini-card">
                                    <Label text="&#xe8b5;" styleClass="support-mini-icon" />
                                    <Label text="Fast reply" styleClass="support-mini-title" />
                                    <Label text="Usually checked during working hours." wrapText="true" styleClass="support-mini-desc" />
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS" styleClass="support-mini-card">
                                    <Label text="&#xe227;" styleClass="support-mini-icon" />
                                    <Label text="Payment help" styleClass="support-mini-title" />
                                    <Label text="Deposit and bid balance questions." wrapText="true" styleClass="support-mini-desc" />
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS" styleClass="support-mini-card">
                                    <Label text="&#xe32a;" styleClass="support-mini-icon" />
                                    <Label text="Account safety" styleClass="support-mini-title" />
                                    <Label text="Login, seller upgrade and security issues." wrapText="true" styleClass="support-mini-desc" />
                                </VBox>
                            </HBox>

                            <VBox spacing="16.0" styleClass="support-card">
                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <StackPane styleClass="support-card-icon-box">
                                        <Label text="&#xe887;" styleClass="support-card-icon" />
                                    </StackPane>
                                    <VBox spacing="3.0">
                                        <Label text="Frequently asked questions" styleClass="support-card-title" />
                                        <Label text="Quick answers for common auction actions." styleClass="support-card-subtitle" />
                                    </VBox>
                                </HBox>

                                <VBox spacing="12.0">
                                    <VBox spacing="5.0" styleClass="support-faq-item">
                                        <Label text="How do I bid on a product?" styleClass="support-faq-question" />
                                        <Label text="Open the auction room, then place a valid bid higher than the current price plus the minimum step price." wrapText="true" styleClass="support-faq-answer" />
                                    </VBox>
                                    <VBox spacing="5.0" styleClass="support-faq-item">
                                        <Label text="How do I deposit funds?" styleClass="support-faq-question" />
                                        <Label text="Open Deposit from the account area, choose an amount, then follow the payment confirmation steps." wrapText="true" styleClass="support-faq-answer" />
                                    </VBox>
                                    <VBox spacing="5.0" styleClass="support-faq-item support-faq-item-last">
                                        <Label text="How can I become a Seller?" styleClass="support-faq-question" />
                                        <Label text="Use Start Selling on the sidebar, read the terms, then submit the seller upgrade request." wrapText="true" styleClass="support-faq-answer" />
                                    </VBox>
                                </VBox>
                            </VBox>

                            <VBox spacing="14.0" styleClass="support-card">
                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <StackPane styleClass="support-card-icon-box">
                                        <Label text="&#xe0c9;" styleClass="support-card-icon" />
                                    </StackPane>
                                    <VBox spacing="3.0">
                                        <Label text="Direct contact channels" styleClass="support-card-title" />
                                        <Label text="Use these channels if the issue is urgent." styleClass="support-card-subtitle" />
                                    </VBox>
                                </HBox>

                                <HBox spacing="12.0" alignment="CENTER_LEFT" styleClass="support-contact-row">
                                    <Label text="&#xe0b0;" styleClass="support-contact-icon" />
                                    <Label text="Support hotline: 1900 6868 (8:00 - 22:00)" wrapText="true" styleClass="support-contact-text" />
                                </HBox>
                                <HBox spacing="12.0" alignment="CENTER_LEFT" styleClass="support-contact-row">
                                    <Label text="&#xe158;" styleClass="support-contact-icon" />
                                    <Label text="Email: lethanhtungbot01@gmail.com" wrapText="true" styleClass="support-contact-text" />
                                </HBox>
                                <HBox spacing="12.0" alignment="CENTER_LEFT" styleClass="support-contact-row">
                                    <Label text="&#xe0c8;" styleClass="support-contact-icon" />
                                    <Label text="Address: Hanoi" wrapText="true" styleClass="support-contact-text" />
                                </HBox>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
</StackPane>