<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" prefWidth="400.0" prefHeight="600.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.SignUpController">
    <padding>
        <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
    </padding>

    <Label text="Đăng ký Tài khoản Mới">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
    </Label>

    <TextField fx:id="txtFullName" promptText="Họ và tên" prefHeight="35.0" />
    <TextField fx:id="txtUsername" promptText="Tên đăng nhập (Dùng để đăng nhập)" prefHeight="35.0" />
    <TextField fx:id="txtEmail" promptText="Email (Dùng để khôi phục mật khẩu)" prefHeight="35.0" />
    <PasswordField fx:id="txtPassword" promptText="Mật khẩu" prefHeight="35.0" />
    <PasswordField fx:id="txtConfirmPassword" promptText="Xác nhận lại mật khẩu" prefHeight="35.0" />

    <Button fx:id="btnSignUp" onAction="#handleSignUp" text="Đăng ký" maxWidth="Infinity" prefHeight="40.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold;" />

    <HBox alignment="CENTER" spacing="5.0">
        <Label text="Đã có tài khoản?" />
        <Hyperlink onAction="#goToLogin" text="Đăng nhập tại đây" />
    </HBox>
</VBox>