<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.AdminDashboardController"
      style="-fx-background-color: #f8fafc;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="ADMIN DASHBOARD">
            <font>
                <Font size="24"/>
            </font>
        </Label>

        <Region HBox.hgrow="ALWAYS" />

        <Button text="Đăng xuất"
                onAction="#handleLogout"
                prefWidth="100" prefHeight="35"
                style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;"/>
    </HBox>

    <TabPane prefHeight="560" tabClosingPolicy="UNAVAILABLE">
        <Tab text="Phiên chờ duyệt">
            <VBox spacing="12">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>

                <TableView fx:id="tablePending" prefHeight="430">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="80"/>
                        <TableColumn fx:id="colProduct" text="Tên sản phẩm" prefWidth="360"/>
                        <TableColumn fx:id="colPrice" text="Giá khởi điểm" prefWidth="180"/>
                    </columns>
                </TableView>

                <HBox spacing="10">
                    <Button text="Approve" onAction="#handleApprove" prefWidth="140" prefHeight="40"
                            style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-size: 14; -fx-background-radius: 10;"/>
                    <Button text="Reject" onAction="#handleReject" prefWidth="140" prefHeight="40"
                            style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 14; -fx-background-radius: 10;"/>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="Danh sách User">
            <VBox spacing="12">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>

                <TableView fx:id="tableUsers" prefHeight="430">
                    <columns>
                        <TableColumn fx:id="colUserId" text="ID" prefWidth="70"/>
                        <TableColumn fx:id="colUsername" text="Username" prefWidth="150"/>
                        <TableColumn fx:id="colFullname" text="Họ tên" prefWidth="190"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="230"/>
                        <TableColumn fx:id="colRole" text="Role" prefWidth="100"/>
                        <TableColumn fx:id="colBanned" text="Banned" prefWidth="90"/>
                    </columns>
                </TableView>

                <HBox spacing="10">
                    <Button text="Khóa tài khoản" onAction="#handleBanUser" prefWidth="160" prefHeight="40"
                            style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 14; -fx-background-radius: 10;"/>
                    <Button text="Refresh" onAction="#handleRefresh" prefWidth="120" prefHeight="40"/>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="Tất cả phiên đấu giá">
            <VBox spacing="12">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>

                <TableView fx:id="tableSessions" prefHeight="430">
                    <columns>
                        <TableColumn fx:id="colSessionId" text="ID" prefWidth="70"/>
                        <TableColumn fx:id="colSessionProduct" text="Tên sản phẩm" prefWidth="300"/>
                        <TableColumn fx:id="colSessionSeller" text="Seller" prefWidth="150"/>
                        <TableColumn fx:id="colSessionPrice" text="Giá khởi điểm" prefWidth="170"/>
                        <TableColumn fx:id="colSessionStatus" text="Trạng thái" prefWidth="130"/>
                    </columns>
                </TableView>

                <HBox spacing="10">
                    <Button text="Hủy phiên" onAction="#handleCancelAuction" prefWidth="140" prefHeight="40"
                            style="-fx-background-color: #f97316; -fx-text-fill: white; -fx-font-size: 14; -fx-background-radius: 10;"/>
                    <Button text="Refresh" onAction="#handleRefresh" prefWidth="120" prefHeight="40"/>
                </HBox>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
