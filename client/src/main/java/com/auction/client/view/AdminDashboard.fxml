<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.layout.StackPane?>

<StackPane stylesheets="@styles.css" styleClass="rounded-window-root" style="-fx-font-family: 'DM Sans'; -fx-background-color: #fff8fd; -fx-background-radius: 32; -fx-border-radius: 32;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AdminDashboardController">
    
    <Region styleClass="admin-solid-window-backdrop" />
<!-- Káº¿t há»£p cáº£ style class cÅ© vÃ  má»›i Ä‘á»ƒ trÃ¡nh lá»—i hiá»ƒn thá»‹ -->
    <BorderPane style=" -fx-background-color: #fff8fd; -fx-background-radius: 30; -fx-border-radius: 30; -fx-border-color: #ffe2f1; -fx-border-width: 1;" prefWidth="1280" prefHeight="720" styleClass="admin-bidpop-root rounded-window-content">

        <top>
            <HBox alignment="CENTER_LEFT" spacing="18" styleClass="admin-bidpop-topbar">
                <Label text="HY Auctions" styleClass="admin-bidpop-brand"/>
                <Label text="Admin Control Panel" styleClass="admin-bidpop-top-chip"/>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- ÄÃ£ giá»¯ láº¡i báº£n dá»‹ch tiáº¿ng Anh "Logout" thay vÃ¬ "ÄÄƒng xuáº¥t" -->
                <Button text="Logout" onAction="#handleLogout" prefHeight="38" styleClass="admin-bidpop-logout-button"/>
                
                <!-- Giá»¯ nguyÃªn cá»¥m nÃºt thao tÃ¡c cá»­a sá»• má»›i (minimize, maximize, close) tá»« nhÃ¡nh main -->
                <HBox alignment="CENTER" spacing="6" style="-fx-padding: 0 0 0 10;">
                    <Button onAction="#handleMinimize" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4;">
                        <graphic>
                            <Label text="&#x2212;" style="-fx-font-family: 'DM Sans'; -fx-font-size: 16px; -fx-font-weight: 900; -fx-text-fill: #907898;" />
                        </graphic>
                    </Button>
                    <Button onAction="#handleMaximize" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4;">
                        <graphic>
                            <Label text="&#x25A1;" style="-fx-font-family: 'DM Sans'; -fx-font-size: 16px; -fx-font-weight: 900; -fx-text-fill: #907898;" />
                        </graphic>
                    </Button>
                    <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4;">
                        <graphic>
                            <Label text="&#x00D7;" style="-fx-font-family: 'DM Sans'; -fx-font-size: 16px; -fx-font-weight: 900; -fx-text-fill: #907898;" />
                        </graphic>
                    </Button>
                </HBox>
            </HBox>
        </top>


    <left>
        <VBox spacing="10" prefWidth="258" minWidth="258" styleClass="admin-bidpop-sidebar">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="admin-bidpop-side-profile">
                <Label text="A" styleClass="admin-bidpop-avatar"/>
                <VBox spacing="1">
                    <Label text="Auction Central" styleClass="admin-bidpop-side-title"/>
                    <Label text="System Administration" styleClass="admin-bidpop-side-subtitle"/>
                </VBox>
            </HBox>

            <Label text="ADMIN TOOLS" styleClass="admin-bidpop-menu-label"/>
            <Button fx:id="btnPendingTab" text="Pending Sessions" alignment="CENTER_LEFT" prefWidth="218" onAction="#showPendingTab" styleClass="admin-nav-button"/>
            <Button fx:id="btnUsersTab" text="User Management" alignment="CENTER_LEFT" prefWidth="218" onAction="#showUsersTab" styleClass="admin-nav-button"/>
            <Button fx:id="btnSessionsTab" text="All Sessions" alignment="CENTER_LEFT" prefWidth="218" onAction="#showSessionsTab" styleClass="admin-nav-button"/>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8" styleClass="admin-bidpop-note-card">
                <Label text="Action Guide" styleClass="admin-bidpop-note-title"/>
                <Label text="Select a row in the table before approving, banning, canceling, or hiding a product." wrapText="true" styleClass="admin-bidpop-note-text"/>
            </VBox>

            <Button text="Refresh Data" onAction="#handleRefresh" prefWidth="218" styleClass="admin-refresh-button"/>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="admin-bidpop-scroll">
            <VBox spacing="22" styleClass="admin-bidpop-content">
                <HBox alignment="CENTER_LEFT" spacing="18">
                    <VBox spacing="4">
                        <Label text="Admin Control Panel" styleClass="admin-bidpop-page-title"/>
                        <Label text="Review auction sessions, manage users and control system operations." styleClass="admin-bidpop-subtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Marketplace Hub" styleClass="admin-bidpop-status-chip"/>
                </HBox>

                <GridPane hgap="16" vgap="16">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                    </columnConstraints>

                    <VBox spacing="8" maxWidth="Infinity" styleClass="admin-bidpop-metric-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Pending" styleClass="admin-bidpop-metric-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Needs review" styleClass="admin-metric-badge"/>
                        </HBox>
                        <Label fx:id="lblPendingCount" text="0" styleClass="admin-bidpop-metric-value"/>
                        <Label text="Sessions awaiting review." wrapText="true" styleClass="admin-bidpop-metric-desc"/>
                    </VBox>

                    <VBox spacing="8" maxWidth="Infinity" styleClass="admin-bidpop-metric-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Users" styleClass="admin-bidpop-metric-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="User" styleClass="admin-metric-badge"/>
                        </HBox>
                        <Label fx:id="lblUserCount" text="0" styleClass="admin-bidpop-metric-value"/>
                        <Label text="Existing accounts." wrapText="true" styleClass="admin-bidpop-metric-desc"/>
                    </VBox>

                    <VBox spacing="8" maxWidth="Infinity" styleClass="admin-bidpop-metric-card" GridPane.columnIndex="2" GridPane.rowIndex="0">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Auction Sessions" styleClass="admin-bidpop-metric-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Total" styleClass="admin-metric-badge"/>
                        </HBox>
                        <Label fx:id="lblSessionCount" text="0" styleClass="admin-bidpop-metric-value"/>
                        <Label text="Total sessions in system." wrapText="true" styleClass="admin-bidpop-metric-desc"/>
                    </VBox>

                    <VBox spacing="8" maxWidth="Infinity" styleClass="admin-bidpop-metric-card" GridPane.columnIndex="3" GridPane.rowIndex="0">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Starting Price" styleClass="admin-bidpop-metric-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="VND" styleClass="admin-metric-badge"/>
                        </HBox>
                        <Label fx:id="lblTotalStartingPrice" text="0 VND" styleClass="admin-bidpop-metric-value"/>
                        <Label text="Total based on current sessions." wrapText="true" styleClass="admin-bidpop-metric-desc"/>
                    </VBox>
                </GridPane>

                <VBox spacing="0" styleClass="admin-bidpop-data-panel" VBox.vgrow="ALWAYS">
                    <TabPane fx:id="adminTabPane"
                             styleClass="navigationless-tab-pane"
                             tabClosingPolicy="UNAVAILABLE"
                             VBox.vgrow="ALWAYS">
                        <tabs>
                            <Tab fx:id="tabPending" text="Pending Sessions">
                                <VBox spacing="16" styleClass="admin-bidpop-table-section" VBox.vgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="admin-bidpop-section-toolbar">
                                        <VBox spacing="2">
                                            <Label text="Pending Auction Sessions" styleClass="admin-bidpop-section-title"/>
                                            <Label text="Select a session to approve or reject." styleClass="admin-bidpop-section-desc"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button text="Approve" onAction="#handleApprove" prefHeight="38" styleClass="admin-success-button"/>
                                        <Button text="Reject" onAction="#handleReject" prefHeight="38" styleClass="admin-danger-button"/>
                                    </HBox>

                                    <TableView fx:id="tablePending" prefHeight="430" VBox.vgrow="ALWAYS" styleClass="admin-table">
                                        <columns>
                                            <TableColumn fx:id="colId" text="ID" prefWidth="70" minWidth="50"/>
                                            <TableColumn fx:id="colProduct" text="Product Name" prefWidth="430" minWidth="160"/>
                                            <TableColumn fx:id="colPrice" text="Starting Price" prefWidth="200" minWidth="120"/>
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                        </columnResizePolicy>
                                    </TableView>
                                </VBox>
                            </Tab>

                            <Tab fx:id="tabUsers" text="User List">
                                <VBox spacing="16" styleClass="admin-bidpop-table-section" VBox.vgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="admin-bidpop-section-toolbar">
                                        <VBox spacing="2">
                                            <Label text="User Management" styleClass="admin-bidpop-section-title"/>
                                            <Label text="Ban or restore accounts as needed." styleClass="admin-bidpop-section-desc"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button text="Ban" onAction="#handleBanUser" prefHeight="38" styleClass="admin-danger-button"/>
                                        <Button text="Restore" onAction="#handleRestoreUser" prefHeight="38" styleClass="admin-success-button"/>
                                    </HBox>

                                    <TableView fx:id="tableUsers" prefHeight="430" VBox.vgrow="ALWAYS" styleClass="admin-table">
                                        <columns>
                                            <TableColumn fx:id="colUserId" text="ID" prefWidth="65" minWidth="45"/>
                                            <TableColumn fx:id="colUsername" text="Username" prefWidth="145" minWidth="90"/>
                                            <TableColumn fx:id="colFullname" text="Full Name" prefWidth="180" minWidth="100"/>
                                            <TableColumn fx:id="colEmail" text="Email" prefWidth="250" minWidth="150"/>
                                            <TableColumn fx:id="colRole" text="Role" prefWidth="95" minWidth="70"/>
                                            <TableColumn fx:id="colBanned" text="Status" prefWidth="115" minWidth="90"/>
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                        </columnResizePolicy>
                                    </TableView>
                                </VBox>
                            </Tab>

                            <Tab fx:id="tabSessions" text="All Auction Sessions">
                                <VBox spacing="16" styleClass="admin-bidpop-table-section" VBox.vgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="admin-bidpop-section-toolbar">
                                        <VBox spacing="2">
                                            <Label text="All Auction Sessions" styleClass="admin-bidpop-section-title"/>
                                            <Label text="Control sessions and product visibility status." styleClass="admin-bidpop-section-desc"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button text="Cancel" onAction="#handleCancelAuction" prefHeight="38" styleClass="admin-warning-button"/>
                                        <Button text="Hide" onAction="#handleHideProduct" prefHeight="38" styleClass="admin-neutral-button"/>
                                        <Button text="Show" onAction="#handleShowProduct" prefHeight="38" styleClass="admin-success-button"/>
                                    </HBox>

                                    <TableView fx:id="tableSessions" prefHeight="430" VBox.vgrow="ALWAYS" styleClass="admin-table">
                                        <columns>
                                            <TableColumn fx:id="colSessionId" text="ID" prefWidth="60" minWidth="45"/>
                                            <TableColumn fx:id="colSessionProduct" text="Product" prefWidth="250" minWidth="130"/>
                                            <TableColumn fx:id="colSessionSeller" text="Seller" prefWidth="135" minWidth="90"/>
                                            <TableColumn fx:id="colSessionPrice" text="Starting Price" prefWidth="155" minWidth="110"/>
                                            <TableColumn fx:id="colSessionStatus" text="Status" prefWidth="125" minWidth="85"/>
                                            <TableColumn fx:id="colProductVisible" text="Visibility" prefWidth="105" minWidth="80"/>
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                        </columnResizePolicy>
                                    </TableView>
                                </VBox>
                            </Tab>
                        </tabs>
                    </TabPane>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
</StackPane>
