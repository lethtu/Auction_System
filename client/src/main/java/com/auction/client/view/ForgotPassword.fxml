<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.ForgotPasswordController" styleClass="auth-root" stylesheets="@../css/auth-theme.css">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <HBox styleClass="auth-shell" maxWidth="1000.0" maxHeight="650.0">
        <!-- Cột trái: Branding -->
        <VBox styleClass="auth-brand-panel" HBox.hgrow="ALWAYS" prefWidth="400.0" alignment="CENTER" spacing="30.0">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
            </padding>
            <VBox alignment="CENTER_LEFT" spacing="10.0" VBox.vgrow="ALWAYS">
                <Label text="Khôi phục Mật khẩu" styleClass="auth-brand-title"/>
                <Label text="Lấy lại quyền truy cập vào tài khoản của bạn chỉ với vài bước đơn giản." styleClass="auth-brand-subtitle"/>
            </VBox>
        </VBox>

        <!-- Cột phải: Form -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS" prefWidth="600.0">
            <padding>
                <Insets bottom="40.0" left="50.0" right="50.0" top="40.0"/>
            </padding>
            <VBox maxWidth="350.0" spacing="25.0" VBox.vgrow="ALWAYS" alignment="CENTER">
                
                <VBox spacing="5.0" alignment="CENTER" maxWidth="Infinity">
                    <HBox spacing="10.0" alignment="CENTER">
                        <Label fx:id="lblStep1" text="1. Email" style="-fx-font-family: 'DM Sans'; -fx-font-weight: bold; -fx-text-fill: #e040a0;"/>
                        <Label text="→" style="-fx-text-fill: #dcc8e0; -fx-font-weight: bold;"/>
                        <Label fx:id="lblStep2" text="2. Verify &amp; Reset" style="-fx-font-family: 'DM Sans'; -fx-font-weight: bold; -fx-text-fill: #907898;"/>
                    </HBox>
                </VBox>

                <!-- Step 1: Email -->
                <VBox fx:id="stepEmail" spacing="20.0" maxWidth="Infinity">
                    <VBox spacing="5.0">
                        <Label text="Email" styleClass="auth-input-label"/>
                        <TextField fx:id="txtEmail" promptText="Nhập Email của bạn" styleClass="auth-input"/>
                    </VBox>
                    <Button fx:id="btnGetOTP" text="Gửi mã xác thực" onAction="#handleGetOTP" maxWidth="Infinity" prefHeight="50.0" styleClass="auth-primary-button"/>
                </VBox>

                <!-- Step 2: Reset -->
                <VBox fx:id="stepReset" spacing="20.0" visible="false" managed="false" maxWidth="Infinity">
                    <VBox spacing="5.0">
                        <Label text="Mã OTP 6 ký tự" styleClass="auth-input-label"/>
                        <TextField fx:id="txtOTP" promptText="Nhập mã OTP" styleClass="auth-input"/>
                    </VBox>
                    <VBox spacing="5.0">
                        <Label text="Mật khẩu mới" styleClass="auth-input-label"/>
                        <PasswordField fx:id="txtNewPassword" promptText="Mật khẩu mới" styleClass="auth-input"/>
                    </VBox>
                    <VBox spacing="5.0">
                        <Label text="Xác nhận mật khẩu" styleClass="auth-input-label"/>
                        <PasswordField fx:id="txtConfirmNewPassword" promptText="Xác nhận mật khẩu" styleClass="auth-input"/>
                    </VBox>

                    <Button fx:id="btnResetPassword" text="Xác nhận Đổi Mật Khẩu" onAction="#handleResetPassword" maxWidth="Infinity" prefHeight="50.0" styleClass="auth-primary-button"/>
                </VBox>

                <HBox alignment="CENTER" spacing="5.0" maxWidth="Infinity">
                    <Hyperlink text="Quay lại đăng nhập" onAction="#goToLogin" styleClass="auth-secondary-link"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</StackPane>