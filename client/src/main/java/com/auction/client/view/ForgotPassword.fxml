<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" prefWidth="400.0" prefHeight="500.0"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.ForgotPasswordController">

    <padding>
        <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
    </padding>

    <Label text="Khôi phục Mật khẩu">
        <font>
            <Font name="System Bold" size="22.0" />
        </font>
    </Label>

    <VBox fx:id="stepEmail" spacing="10.0" alignment="CENTER">
        <Label text="Vui lòng nhập Email để nhận mã xác thực." textAlignment="CENTER" wrapText="true" textFill="#6c757d" />
        <TextField fx:id="txtEmail" promptText="Nhập Email của bạn" prefHeight="35.0" />
        <Button fx:id="btnGetOTP" onAction="#handleGetOTP" text="Gửi mã OTP" maxWidth="Infinity" prefHeight="40.0"
                style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-weight: bold;" />
    </VBox>

    <VBox fx:id="stepReset" spacing="10.0" alignment="CENTER" visible="false" managed="false">
        <Separator />
        <Label text="Nhập mã OTP và mật khẩu mới bên dưới:" textFill="#28a745" />
        <TextField fx:id="txtOTP" promptText="Mã OTP (6 số)" prefHeight="35.0" />
        <PasswordField fx:id="txtNewPassword" promptText="Mật khẩu mới" prefHeight="35.0" />
        <PasswordField fx:id="txtConfirmNewPassword" promptText="Xác nhận mật khẩu" prefHeight="35.0" />

        <Button onAction="#handleResetPassword" text="Xác nhận Đổi Mật Khẩu" maxWidth="Infinity" prefHeight="40.0"
                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold;" />
    </VBox>

    <HBox alignment="CENTER" spacing="5.0">
        <Hyperlink onAction="#goToLogin" text="&lt; Quay lại trang Đăng nhập" style="-fx-text-fill: #007bff;" />
    </HBox>
</VBox>