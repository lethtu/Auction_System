<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<HBox fx:id="topbar" alignment="CENTER_LEFT" spacing="0.0" styleClass="app-topbar" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.TopbarController">
    <StackPane prefWidth="70.0" minWidth="70.0" maxWidth="70.0">
        <Button fx:id="btnHamburger" id="btnHamburger" onAction="#handleToggleSidebar" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;">
            <graphic>
                <Label text="&#xe5d2;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: -app-text-muted;" />
            </graphic>
        </Button>
    </StackPane>
    <Label fx:id="logoBrand" id="logoBrand" text="BidPop" onMouseClicked="#handleGoToDashboard" style="-fx-cursor: hand; -fx-text-fill: -fx-accent; -fx-font-weight: 900; -fx-font-size: 28px; -fx-font-family: 'DM Sans';" />

    <Region HBox.hgrow="ALWAYS" />

    <HBox fx:id="searchContainer" alignment="CENTER_LEFT" prefWidth="500.0" prefHeight="40.0" style="-fx-background-color: -app-input-bg; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 999; -fx-background-radius: 999; -fx-padding: 0 16px; -fx-effect: dropshadow(three-pass-box, -app-accent-opacity-05, 10, 0, 0, 2);">
        <Label text="&#xe8b6;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: -fx-accent;" translateY="0.0" />
        <TextField fx:id="txtSearch" promptText="Search items, categories, or auctions..." HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-background-insets: 0; -fx-border-width: 0; -fx-padding: 0 0 0 8px; -fx-prompt-text-fill: -app-placeholder; -fx-text-fill: -app-input-text; -fx-font-size: 14px;" />
    </HBox>

    <Region HBox.hgrow="ALWAYS" />

    <HBox spacing="10.0" alignment="CENTER_RIGHT" minHeight="52.0" prefHeight="52.0" maxHeight="52.0" style="-fx-padding: 0;">
        <StackPane alignment="CENTER" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0">
            <Button fx:id="btnNotificationBell" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center;">
                <graphic>
                    <Label text="&#xe7f4;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: -app-text-muted;" />
                </graphic>
            </Button>
            <Label fx:id="notificationBadge" text="0" visible="false" managed="false" style="-fx-background-color: -fx-accent; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 1 5; -fx-background-radius: 10; -fx-translate-x: 12; -fx-translate-y: -12;" />
        </StackPane>
        <Button fx:id="btnSettings" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center;">
            <graphic>
                <Label text="&#xe8b8;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: -app-text-muted;" />
            </graphic>
        </Button>
        <MenuButton fx:id="userMenuButton" id="profile-menu" minWidth="54.0" prefWidth="54.0" maxWidth="54.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center; -fx-background-insets: 0;">
            <graphic>
                <StackPane fx:id="topBarAvatarPane" styleClass="topbar-avatar-frame" minWidth="44" maxWidth="44" minHeight="44" maxHeight="44" prefWidth="44" prefHeight="44">
                    <Label text="&#xe7fd;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: white;" />
                </StackPane>
            </graphic>
        </MenuButton>
        <HBox alignment="CENTER" spacing="8" styleClass="mac-window-controls">
            <Button accessibleText="Minimize" onAction="#handleMinimize" styleClass="mac-window-control,mac-minimize" />
            <Button accessibleText="Maximize" onAction="#handleMaximize" styleClass="mac-window-control,mac-maximize" />
            <Button accessibleText="Close" onAction="#handleClose" styleClass="mac-window-control,mac-close" />
        </HBox>
    </HBox>
</HBox>
