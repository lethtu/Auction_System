<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefWidth="1280.0" prefHeight="800.0" stylesheets="@styles.css" style="-fx-background-color: #fef7ff; -fx-font-family: 'DM Sans';" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.SettingsController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: rgba(254, 247, 255, 0.9); -fx-padding: 12px 30px; -fx-border-color: #ffe8e8; -fx-border-width: 0 0 2px 0; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.15), 20, 0, 0, 4);">
            <Button fx:id="btnHamburger" onAction="#handleToggleSidebar" style="-fx-background-color: transparent; -fx-cursor: hand;">
                <graphic>
                    <Label text="&#xe5d2;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" />
                </graphic>
            </Button>
            <Label text="HY Auction" textFill="#e040a0" onMouseClicked="#handleGoToDashboard" style="-fx-cursor: hand; -fx-font-weight: bold;">
                <font>
                    <Font name="System Bold" size="28.0" />
                </font>
            </Label>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox alignment="CENTER_LEFT" prefWidth="500.0" prefHeight="40.0" style="-fx-background-color: #ffffff; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 999; -fx-background-radius: 999; -fx-padding: 0 16px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.05), 10, 0, 0, 2);">
                <Label text="&#xe8b6;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #e040a0;" translateY="3.0" />
                <TextField fx:id="txtSearch" promptText="Search items, categories, or auctions..." HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-padding: 0 0 0 8px; -fx-prompt-text-fill: #907898; -fx-text-fill: #2e1a28; -fx-font-size: 14px;" />
            </HBox>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox spacing="10.0" alignment="CENTER_RIGHT" minHeight="52.0" prefHeight="52.0" maxHeight="52.0" style="-fx-padding: 0;">
                <StackPane alignment="CENTER" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0">
                    <Button fx:id="btnNotificationBell" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center;">
                        <graphic>
                            <Label text="&#xe7f4;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" />
                        </graphic>
                    </Button>
                    <Label fx:id="notificationBadge" text="0" visible="false" managed="false" style="-fx-background-color: #e040a0; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 1 5; -fx-background-radius: 10; -fx-translate-x: 12; -fx-translate-y: -12;" />
                </StackPane>
                <Button fx:id="btnSettings" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center;">
                    <graphic>
                        <Label text="&#xe8b8;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #e040a0;" />
                    </graphic>
                </Button>
                <MenuButton fx:id="userMenuButton" id="profile-menu" minWidth="58.0" prefWidth="58.0" maxWidth="58.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center; -fx-background-insets: 0;">
                    <graphic>
                        <StackPane fx:id="topBarAvatarPane" minWidth="44" maxWidth="44" minHeight="44" maxHeight="44" prefWidth="44" prefHeight="44" style="-fx-background-color: #1a1a3a; -fx-background-radius: 22px;">
                            <Label text="&#xe7fd;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: white;" />
                        </StackPane>
                    </graphic>
                </MenuButton>
            </HBox>
        </HBox>
    </top>

    <left>
        <fx:include source="Sidebar.fxml" fx:id="sidebar" />
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="35.0" style="-fx-padding: 40px 60px;">
                <!-- Header Title -->
                <VBox spacing="10.0">
                    <Label text="CẤU HÌNH &amp; CÀI ĐẶT HỆ THỐNG" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2e1a28;" />
                    <Label text="Tùy chỉnh thông báo, giao diện ứng dụng và trải nghiệm đấu giá của bạn." style="-fx-font-size: 15px; -fx-text-fill: #604868;" />
                </VBox>

                <!-- 2-Column Grid Area -->
                <HBox spacing="40.0" alignment="TOP_LEFT">
                    <!-- Column 1: Config Form (Left) -->
                    <VBox spacing="24.0" prefWidth="540.0" minWidth="440.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #ffffff; -fx-padding: 30px; -fx-background-radius: 24px; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.06), 20, 0, 0, 6);">
                        <Label text="CẤU HÌNH ỨNG DỤNG" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e040a0;" />
                        
                        <!-- Notifications -->
                        <VBox spacing="12.0">
                            <Label text="THÔNG BÁO &amp; ÂM THANH" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #e040a0; -fx-padding: 0 0 4px 0;" />
                            
                            <CheckBox fx:id="chkOutbid" text="Nhận thông báo khi bị vượt giá" style="-fx-font-size: 14px; -fx-text-fill: #2e1a28; -fx-cursor: hand;" />
                            <CheckBox fx:id="chkSound" text="Phát âm thanh thông báo" style="-fx-font-size: 14px; -fx-text-fill: #2e1a28; -fx-cursor: hand;" />
                        </VBox>

                        <Separator style="-fx-background-color: #ffe8e8; -fx-opacity: 0.5;" />

                        <!-- UI Experience -->
                        <VBox spacing="16.0">
                            <Label text="GIAO DIỆN &amp; TRẢI NGHIỆM" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #e040a0; -fx-padding: 0 0 4px 0;" />
                            
                            <CheckBox fx:id="chkCollapse" text="Tự động thu gọn thanh bên (Sidebar)" style="-fx-font-size: 14px; -fx-text-fill: #2e1a28; -fx-cursor: hand;" />

                            <!-- Language -->
                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                <Label text="Ngôn ngữ ứng dụng:" style="-fx-font-size: 14px; -fx-text-fill: #2e1a28;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <ComboBox fx:id="cbLang" prefWidth="180.0" style="-fx-background-color: #ffffff; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-cursor: hand;" />
                            </HBox>

                            <!-- Accent Color -->
                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                <Label text="Tông màu chủ đạo:" style="-fx-font-size: 14px; -fx-text-fill: #2e1a28;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <ComboBox fx:id="cbColor" prefWidth="180.0" style="-fx-background-color: #ffffff; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-cursor: hand;" />
                            </HBox>
                        </VBox>

                        <Label fx:id="lblStatus" text="" visible="false" managed="false" style="-fx-font-size: 14px; -fx-font-weight: bold;" />

                        <Button fx:id="btnSaveSettings" onAction="#handleSaveSettings" text="Lưu Cài Đặt" maxWidth="Infinity" prefHeight="48.0" style="-fx-background-color: #e040a0; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 24px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.3), 12, 0, 0, 4);">
                            <graphic>
                                <Label text="&#xe876;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: white;" translateY="2.0" />
                            </graphic>
                        </Button>
                    </VBox>

                    <!-- Column 2: Quick Actions (Right) -->
                    <VBox spacing="24.0" HBox.hgrow="ALWAYS">
                        <VBox spacing="20.0" style="-fx-background-color: #ffffff; -fx-padding: 30px; -fx-background-radius: 24px; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.06), 20, 0, 0, 6);">
                            <Label text="THAO TÁC NHANH" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e040a0;" />
                            <Label text="Dưới đây là một số phím tắt điều chỉnh bộ lọc tìm kiếm và đồng bộ hóa lại dữ liệu trực tiếp từ máy chủ đấu giá." wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #604868;" />

                            <HBox spacing="15.0">
                                <Button fx:id="btnResetFilters" onAction="#handleResetFilters" text="Đặt lại bộ lọc" prefHeight="40.0" style="-fx-background-color: #fff1fa; -fx-text-fill: #8a2b66; -fx-font-weight: bold; -fx-background-radius: 10px; -fx-border-color: #f6a6d7; -fx-border-radius: 10px; -fx-padding: 8px 20px; -fx-cursor: hand;" />
                                <Button fx:id="btnReloadData" onAction="#handleReloadData" text="Tải lại dữ liệu" prefHeight="40.0" style="-fx-background-color: #fff1fa; -fx-text-fill: #8a2b66; -fx-font-weight: bold; -fx-background-radius: 10px; -fx-border-color: #f6a6d7; -fx-border-radius: 10px; -fx-padding: 8px 20px; -fx-cursor: hand;" />
                            </HBox>
                        </VBox>

                        <VBox spacing="16.0" style="-fx-background-color: #ffffff; -fx-padding: 30px; -fx-background-radius: 24px; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.06), 20, 0, 0, 6);">
                            <Label text="THÔNG TIN HỆ THỐNG" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e040a0;" />
                            
                            <HBox spacing="12.0" alignment="CENTER_LEFT">
                                <Label text="&#xe8d4;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #e040a0;" />
                                <Label text="Phiên bản ứng dụng: 0.1 (Stable)" style="-fx-font-size: 14px; -fx-text-fill: #2e1a28; -fx-font-weight: bold;" />
                            </HBox>

                            <HBox spacing="12.0" alignment="CENTER_LEFT">
                                <Label text="&#xe1b1;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #e040a0;" />
                                <Label text="Trạng thái máy chủ: Đang kết nối tốt" style="-fx-font-size: 14px; -fx-text-fill: #2e1a28; -fx-font-weight: bold;" />
                            </HBox>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
