<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefWidth="1280.0" prefHeight="800.0" stylesheets="@styles.css" styleClass="rounded-window-root" style="-fx-font-family: 'DM Sans';" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.SettingsController">
    <BorderPane styleClass="rounded-window-content">
        <top>
            <fx:include source="Topbar.fxml" fx:id="topbar" />
        </top>

        <left>
            <fx:include source="Sidebar.fxml" fx:id="sidebar">
                <BorderPane.margin>
                    <Insets top="14.0" right="0.0" bottom="14.0" left="14.0" />
                </BorderPane.margin>
            </fx:include>
        </left>

        <center>
            <VBox spacing="20.0" styleClass="app-content-panel">
                <BorderPane.margin>
                    <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
                </BorderPane.margin>

                <HBox spacing="10.0" alignment="BOTTOM_LEFT" style="-fx-padding: 0 0 10px 0;">
                    <VBox spacing="10.0">
                        <Label text="System Settings" styleClass="settings-page-title" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: -fx-accent;" />
                        <Label text="Customize notifications, app interface and your auction experience." styleClass="settings-page-subtitle" style="-fx-font-size: 15px;" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnSaveSettingsTop" onAction="#handleSaveSettings" text="Save Changes" prefHeight="40.0" styleClass="primary-btn" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-cursor: hand;">
                        <graphic>
                            <Label text="&#xe876;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 18px; -fx-text-fill: white;" translateY="1.0" />
                        </graphic>
                    </Button>
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
                    <VBox spacing="24.0" style="-fx-padding: 10px;">
                        <VBox fx:id="passwordSetBox" spacing="16.0" styleClass="password-security-card password-security-card-warning">
                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                <Label text="&#xe8a6;" styleClass="password-security-icon" />
                                <Label text="Set account password" styleClass="password-security-title" />
                            </HBox>
                            <Label text="This account was created through Google sign-in and does not have a local password yet." wrapText="true" styleClass="password-security-description" />
                            <HBox spacing="20.0" alignment="CENTER_LEFT">
                                <PasswordField fx:id="txtNewPassword" promptText="New password, at least 6 characters" prefWidth="260.0" />
                                <PasswordField fx:id="txtConfirmPassword" promptText="Confirm new password" prefWidth="220.0" />
                                <Button fx:id="btnSetPassword" onAction="#handleSetPassword" text="Set Password" prefHeight="40.0" styleClass="password-security-primary-btn" />
                            </HBox>
                        </VBox>

                        <VBox fx:id="passwordChangeBox" spacing="16.0" styleClass="password-security-card">
                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                <Label text="&#xe897;" styleClass="password-security-icon" />
                                <Label text="Change password" styleClass="password-security-title" />
                            </HBox>
                            <Label text="Update your local password. Use a password with at least 6 characters." wrapText="true" styleClass="password-security-description" />
                            <HBox spacing="20.0" alignment="CENTER_LEFT">
                                <PasswordField fx:id="txtCurrentPassword" promptText="Current password" prefWidth="220.0" />
                                <PasswordField fx:id="txtChangeNewPassword" promptText="New password" prefWidth="220.0" />
                                <PasswordField fx:id="txtChangeConfirmPassword" promptText="Confirm new password" prefWidth="220.0" />
                                <Button fx:id="btnChangePassword" onAction="#handleChangePassword" text="Change Password" prefHeight="40.0" styleClass="password-security-primary-btn" />
                            </HBox>
                        </VBox>

                        <FlowPane hgap="30.0" vgap="30.0" prefWrapLength="1000.0">
                            <VBox spacing="20.0" prefWidth="480.0" styleClass="settings-card" style="-fx-padding: 24px; -fx-background-radius: 16px; -fx-border-radius: 16px; -fx-border-width: 1px;">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="&#xe7f4;" styleClass="accent-icon" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 24px;" />
                                    <Label text="Notifications &amp; Sounds" styleClass="settings-card-title" />
                                </HBox>
                                <Separator />
                                <CheckBox fx:id="chkNotificationsEnabled" text="Enable app notifications" styleClass="setting-switch" />
                                <CheckBox fx:id="chkOutbid" text="Notify when outbid" styleClass="setting-switch" />
                                <CheckBox fx:id="chkEndingSoon" text="Notify when auction ending soon" styleClass="setting-switch" />
                                <CheckBox fx:id="chkAuctionResult" text="Notify on auction win/loss" styleClass="setting-switch" />
                                <Separator />
                                <CheckBox fx:id="chkSound" text="Play sound effects" styleClass="setting-switch" />
                                <HBox spacing="15" alignment="CENTER_LEFT">
                                    <Label text="Volume:" styleClass="setting-label" />
                                    <Slider fx:id="sliderVolume" min="0" max="100" value="60" HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblVolumeValue" text="60%" styleClass="setting-label" />
                                </HBox>
                                <Button text="Test Notification Sound" onAction="#handleTestSound" styleClass="secondary-btn" />
                            </VBox>

                            <VBox spacing="20.0" prefWidth="480.0" styleClass="settings-card" style="-fx-padding: 24px; -fx-background-radius: 16px; -fx-border-radius: 16px; -fx-border-width: 1px;">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="&#xe3b5;" styleClass="accent-icon" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 24px;" />
                                    <Label text="Appearance" styleClass="settings-card-title" />
                                </HBox>
                                <Separator />
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Theme:" styleClass="setting-label" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <ComboBox fx:id="cbTheme" prefWidth="180" />
                                </HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Accent Color:" styleClass="setting-label" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <ComboBox fx:id="cbColor" prefWidth="180" />
                                </HBox>
                                <Separator />
                                <CheckBox fx:id="chkCollapse" text="Auto-collapse sidebar" styleClass="setting-switch" />
                                <CheckBox fx:id="chkRememberPage" text="Remember last page on startup" styleClass="setting-switch" />
                            </VBox>

                            <VBox spacing="20.0" prefWidth="480.0" styleClass="settings-card" style="-fx-padding: 24px; -fx-background-radius: 16px; -fx-border-radius: 16px; -fx-border-width: 1px;">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="&#xe8d0;" styleClass="accent-icon" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 24px;" />
                                    <Label text="Auction Preferences" styleClass="settings-card-title" />
                                </HBox>
                                <Separator />
                                <CheckBox fx:id="chkConfirmBid" text="Confirm before placing bid" styleClass="setting-switch" />
                                <CheckBox fx:id="chkQuickBid" text="Enable Quick Bid buttons" styleClass="setting-switch" />
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="High bid warning (VND):" styleClass="setting-label" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <TextField fx:id="txtHighBidWarning" prefWidth="140" />
                                </HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Default bid increment (VND):" styleClass="setting-label" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <TextField fx:id="txtDefaultIncrement" prefWidth="140" />
                                </HBox>
                            </VBox>

                            <VBox spacing="20.0" prefWidth="480.0" styleClass="settings-card" style="-fx-padding: 24px; -fx-background-radius: 16px; -fx-border-radius: 16px; -fx-border-width: 1px;">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="&#xe871;" styleClass="accent-icon" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 24px;" />
                                    <Label text="Dashboard Display" styleClass="settings-card-title" />
                                </HBox>
                                <Separator />
                                <CheckBox fx:id="chkShowEnded" text="Show ended auctions by default" styleClass="setting-switch" />
                                <CheckBox fx:id="chkSortActive" text="Sort active auctions first" styleClass="setting-switch" />
                                <CheckBox fx:id="chkShowCountdown" text="Show countdown timers" styleClass="setting-switch" />
                                <CheckBox fx:id="chkCompactCards" text="Use compact product cards" styleClass="setting-switch" />
                            </VBox>

                            <VBox spacing="20.0" prefWidth="480.0" styleClass="settings-card" style="-fx-padding: 24px; -fx-background-radius: 16px; -fx-border-radius: 16px; -fx-border-width: 1px;">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="&#xe8b8;" styleClass="accent-icon" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 24px;" />
                                    <Label text="System &amp; Data" styleClass="settings-card-title" />
                                </HBox>
                                <Separator />
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="App Version:" styleClass="setting-label" />
                                    <Label text="0.1.0 Stable" styleClass="setting-label" />
                                </HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Server Status:" styleClass="setting-label" />
                                    <Label text="Connected" style="-fx-text-fill: #10b981;" />
                                </HBox>
                                <HBox spacing="15" style="-fx-padding: 10px 0 0 0;">
                                    <Button onAction="#handleResetFilters" text="Reset Filters" styleClass="secondary-btn" />
                                    <Button onAction="#handleReloadData" text="Sync Latest Data" styleClass="secondary-btn" />
                                </HBox>
                            </VBox>
                        </FlowPane>
                    </VBox>
                </ScrollPane>
            </VBox>
        </center>
    </BorderPane>
    <VBox fx:id="toastContainer" pickOnBounds="false" alignment="BOTTOM_RIGHT" spacing="10" style="-fx-padding: 30px;" />
</StackPane>
