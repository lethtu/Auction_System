<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefWidth="1280.0" prefHeight="800.0" stylesheets="@styles.css" styleClass="rounded-window-root" style="-fx-font-family: 'DM Sans';" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.SettingsController">
<BorderPane styleClass="rounded-window-content">

    <top>
        <fx:include source="Topbar.fxml" fx:id="topbar"/>
    </top>

    <left>
        <fx:include source="Sidebar.fxml" fx:id="sidebar">
            <BorderPane.margin>
                <Insets top="14.0" right="0.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
        </fx:include>
    </left>

    <center>
        <VBox spacing="20.0" styleClass="app-content-panel">
            <BorderPane.margin>
                <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
            <!-- Header Title -->
            <VBox spacing="10.0" style="-fx-padding: 0 0 10px 0;">
                <Label text="CONFIGURATION &amp; SYSTEM SETTINGS" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2e1a28;" />
                <Label text="Customize notifications, app interface and your auction experience." style="-fx-font-size: 15px; -fx-text-fill: #604868;" />
            </VBox>
            
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="35.0" style="-fx-padding: 10px 0px;">

                <!-- 2-Column Grid Area -->
                <HBox spacing="40.0" alignment="TOP_LEFT">
                    <!-- Column 1: Config Form (Left) -->
                    <VBox spacing="24.0" prefWidth="540.0" minWidth="440.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #ffffff; -fx-padding: 30px; -fx-background-radius: 24px; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.06), 20, 0, 0, 6);">
                        <Label text="APP CONFIGURATION" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e040a0;" />
                        
                        <!-- Notifications -->
                        <VBox spacing="12.0">
                            <Label text="NOTIFICATIONS &amp; SOUNDS" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #e040a0; -fx-padding: 0 0 4px 0;" />
                            
                            <CheckBox fx:id="chkOutbid" text="Receive notification when outbid" style="-fx-font-size: 14px; -fx-text-fill: #2e1a28; -fx-cursor: hand;" />
                            <CheckBox fx:id="chkSound" text="Play notification sounds" style="-fx-font-size: 14px; -fx-text-fill: #2e1a28; -fx-cursor: hand;" />
                        </VBox>

                        <Separator style="-fx-background-color: #ffe8e8; -fx-opacity: 0.5;" />

                        <!-- UI Experience -->
                        <VBox spacing="16.0">
                            <Label text="INTERFACE &amp; EXPERIENCE" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #e040a0; -fx-padding: 0 0 4px 0;" />
                            
                            <CheckBox fx:id="chkCollapse" text="Auto-collapse sidebar" style="-fx-font-size: 14px; -fx-text-fill: #2e1a28; -fx-cursor: hand;" />

                            <!-- Language -->
                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                <Label text="App language:" style="-fx-font-size: 14px; -fx-text-fill: #2e1a28;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <ComboBox fx:id="cbLang" prefWidth="180.0" style="-fx-background-color: #ffffff; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-cursor: hand;" />
                            </HBox>

                            <!-- Accent Color -->
                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                <Label text="Primary color tone:" style="-fx-font-size: 14px; -fx-text-fill: #2e1a28;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <ComboBox fx:id="cbColor" prefWidth="180.0" style="-fx-background-color: #ffffff; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-cursor: hand;" />
                            </HBox>
                        </VBox>

                        <Label fx:id="lblStatus" text="" visible="false" managed="false" style="-fx-font-size: 14px; -fx-font-weight: bold;" />

                        <Button fx:id="btnSaveSettings" onAction="#handleSaveSettings" text="Save Settings" maxWidth="Infinity" prefHeight="48.0" style="-fx-background-color: #e040a0; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 24px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.3), 12, 0, 0, 4);">
                            <graphic>
                                <Label text="&#xe876;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: white;" translateY="2.0" />
                            </graphic>
                        </Button>
                    </VBox>

                    <!-- Column 2: Quick Actions (Right) -->
                    <VBox spacing="24.0" HBox.hgrow="ALWAYS">
                        <VBox spacing="20.0" style="-fx-background-color: #ffffff; -fx-padding: 30px; -fx-background-radius: 24px; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.06), 20, 0, 0, 6);">
                            <Label text="QUICK ACTIONS" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e040a0;" />
                            <Label text="Below are some shortcuts to adjust search filters and resynchronize data directly from the auction server." wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #604868;" />

                            <HBox spacing="15.0">
                                <Button fx:id="btnResetFilters" onAction="#handleResetFilters" text="Reset Filters" prefHeight="40.0" style="-fx-background-color: #fff1fa; -fx-text-fill: #8a2b66; -fx-font-weight: bold; -fx-background-radius: 10px; -fx-border-color: #f6a6d7; -fx-border-radius: 10px; -fx-padding: 8px 20px; -fx-cursor: hand;" />
                                <Button fx:id="btnReloadData" onAction="#handleReloadData" text="Reload Data" prefHeight="40.0" style="-fx-background-color: #fff1fa; -fx-text-fill: #8a2b66; -fx-font-weight: bold; -fx-background-radius: 10px; -fx-border-color: #f6a6d7; -fx-border-radius: 10px; -fx-padding: 8px 20px; -fx-cursor: hand;" />
                            </HBox>
                        </VBox>

                        <VBox spacing="16.0" style="-fx-background-color: #ffffff; -fx-padding: 30px; -fx-background-radius: 24px; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.06), 20, 0, 0, 6);">
                            <Label text="SYSTEM INFORMATION" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e040a0;" />
                            
                            <HBox spacing="12.0" alignment="CENTER_LEFT">
                                <Label text="&#xe8d4;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #e040a0;" />
                                <Label text="App version: 0.1 (Stable)" style="-fx-font-size: 14px; -fx-text-fill: #2e1a28; -fx-font-weight: bold;" />
                            </HBox>

                            <HBox spacing="12.0" alignment="CENTER_LEFT">
                                <Label text="&#xe1b1;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #e040a0;" />
                                <Label text="Server status: Connected" style="-fx-font-size: 14px; -fx-text-fill: #2e1a28; -fx-font-weight: bold;" />
                            </HBox>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
        </VBox>
    </center>
</BorderPane>
    <VBox fx:id="toastContainer" pickOnBounds="false" alignment="BOTTOM_RIGHT" spacing="10" style="-fx-padding: 30px;" />
</StackPane>
