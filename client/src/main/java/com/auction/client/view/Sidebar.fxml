<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fx:id="sidebarContainer" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: #f2e8f2; -fx-border-width: 0 2px 0 0;" minWidth="200.0" prefWidth="200.0" maxWidth="200.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.SidebarController">
    <VBox fx:id="sidebarContent" spacing="4.0" style="-fx-background-color: #ffffff; -fx-padding: 24px 8px;">
        <!-- Main Menu -->
        <Label text="MAIN MENU" style="-fx-text-fill: #907898; -fx-font-family: 'DM Sans'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 4px 16px;" />
        <Button fx:id="btnSidebarDashboard" onAction="#handleDashboard" text="Dashboard" alignment="CENTER_LEFT" prefWidth="165.0" minWidth="165.0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 14px; -fx-background-color: rgba(224, 64, 160, 0.15); -fx-text-fill: #e040a0; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-padding: 7px 16px; -fx-cursor: hand;">
            <graphic><Label text="&#xe871;" minWidth="24.0" minHeight="24.0" alignment="CENTER" translateY="3.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #e040a0;" /></graphic>
        </Button>
        <Button fx:id="btnMyBids" onAction="#handleMyBids" text="My Bids" alignment="CENTER_LEFT" prefWidth="165.0" minWidth="165.0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 14px; -fx-background-color: transparent; -fx-text-fill: #604868; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-padding: 7px 16px; -fx-cursor: hand;">
            <graphic><Label text="&#xe90e;" minWidth="24.0" minHeight="24.0" alignment="CENTER" translateY="3.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" /></graphic>
        </Button>
        <Button fx:id="btnSelling" onAction="#handleSelling" text="Selling" alignment="CENTER_LEFT" prefWidth="165.0" minWidth="165.0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 14px; -fx-background-color: transparent; -fx-text-fill: #604868; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-padding: 7px 16px; -fx-cursor: hand;">
            <graphic><Label text="&#xea12;" minWidth="24.0" minHeight="24.0" alignment="CENTER" translateY="3.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" /></graphic>
        </Button>
        
        <Region prefHeight="8.0" />
        
        <!-- Discover -->
        <Label text="DISCOVER" style="-fx-text-fill: #907898; -fx-font-family: 'DM Sans'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 4px 16px;" />
        <Button fx:id="btnCategories" onAction="#handleCategories" text="Categories" alignment="CENTER_LEFT" prefWidth="165.0" minWidth="165.0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 14px; -fx-background-color: transparent; -fx-text-fill: #604868; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-padding: 7px 16px; -fx-cursor: hand;">
            <graphic><Label text="&#xe574;" minWidth="24.0" minHeight="24.0" alignment="CENTER" translateY="3.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" /></graphic>
        </Button>
        <Button fx:id="btnSidebarWatchlist" onAction="#handleWatchlist" text="Watchlist" alignment="CENTER_LEFT" prefWidth="165.0" minWidth="165.0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 14px; -fx-background-color: transparent; -fx-text-fill: #604868; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-padding: 7px 16px; -fx-cursor: hand;">
            <graphic><Label text="&#xe8f4;" minWidth="24.0" minHeight="24.0" alignment="CENTER" translateY="3.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" /></graphic>
        </Button>
        
        <Region prefHeight="8.0" />
        
        <!-- Other -->
        <Label text="OTHER" style="-fx-text-fill: #907898; -fx-font-family: 'DM Sans'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 4px 16px;" />
        <Button fx:id="btnSupport" onAction="#handleSupport" text="Support" alignment="CENTER_LEFT" prefWidth="165.0" minWidth="165.0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 14px; -fx-background-color: transparent; -fx-text-fill: #604868; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-padding: 7px 16px; -fx-cursor: hand;">
            <graphic><Label text="&#xe887;" minWidth="24.0" minHeight="24.0" alignment="CENTER" translateY="3.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" /></graphic>
        </Button>
        
        <Region VBox.vgrow="ALWAYS" />

        <!-- Start Selling Button -->
        <Button fx:id="btnStartSelling" onAction="#handleStartSelling" text="Start Selling" prefWidth="165.0" minWidth="165.0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 14px; -fx-background-color: #e040a0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-padding: 12px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.3), 16, 0, 0, 4);">
            <graphic><Label text="&#xe145;" minWidth="24.0" minHeight="24.0" alignment="CENTER" translateY="3.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: white;" /></graphic>
        </Button>
    </VBox>
</ScrollPane>
