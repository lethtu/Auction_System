<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.paint.Color?>

<BorderPane prefWidth="1280.0" prefHeight="800.0" stylesheets="@styles.css" style="-fx-background-color: #fef7ff; -fx-font-family: 'DM Sans';" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.UpToSellerController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0.0" style="-fx-background-color: rgba(254, 247, 255, 0.9); -fx-padding: 12px 30px 12px 0px; -fx-border-color: #ffe8e8; -fx-border-width: 0 0 2px 0; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.15), 20, 0, 0, 4);">
            <StackPane prefWidth="70.0" minWidth="70.0" maxWidth="70.0">
                <Button fx:id="btnHamburger" onAction="#handleToggleSidebar" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;">
                    <graphic>
                        <Label text="&#xe5d2;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" />
                    </graphic>
                </Button>
            </StackPane>
            <Label text="HY Auction" textFill="#e040a0" onMouseClicked="#handleGoBack" style="-fx-cursor: hand;">
                <font>
                    <Font name="System Bold" size="28.0" />
                </font>
            </Label>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox alignment="CENTER_LEFT" prefWidth="500.0" prefHeight="40.0" style="-fx-background-color: #ffffff; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 999; -fx-background-radius: 999; -fx-padding: 0 16px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.05), 10, 0, 0, 2);">
                <Label text="&#xe8b6;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #e040a0;" translateY="0.0" />
                <TextField fx:id="txtSearch" promptText="Search items, categories, or auctions..." HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-padding: 0 0 0 8px; -fx-prompt-text-fill: #907898; -fx-text-fill: #2e1a28; -fx-font-size: 14px;" />
            </HBox>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox spacing="10.0" alignment="CENTER_RIGHT" minHeight="52.0" prefHeight="52.0" maxHeight="52.0" style="-fx-padding: 0;">
                <StackPane alignment="CENTER" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0">
                    <Button fx:id="btnNotificationBell" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center;">
                        <graphic>
                            <Label text="&#xe7f4;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" />
                        </graphic>
                    </Button>
                    <Label fx:id="notificationBadge" text="0" visible="false" managed="false" style="-fx-background-color: #e040a0; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 1 5; -fx-background-radius: 10; -fx-translate-x: 12; -fx-translate-y: -12;" />
                </StackPane>
                <Button fx:id="btnSettings" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center;">
                    <graphic>
                        <Label text="&#xe8b8;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" />
                    </graphic>
                </Button>
                <MenuButton fx:id="userMenuButton" id="profile-menu" minWidth="58.0" prefWidth="58.0" maxWidth="58.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center; -fx-background-insets: 0;">
                    <graphic>
                        <StackPane minWidth="44" maxWidth="44" minHeight="44" maxHeight="44" prefWidth="44" prefHeight="44" style="-fx-background-color: #1a1a3a; -fx-background-radius: 22px;">
                            <Label text="&#xe7fd;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: white;" />
                        </StackPane>
                    </graphic>
                </MenuButton>
            </HBox>
        </HBox>
    </top>

    <left>
        <fx:include source="Sidebar.fxml" fx:id="sidebar" />
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox alignment="CENTER" spacing="35.0" style="-fx-padding: 40px 60px;">
                <!-- Hero Banner / Title -->
                <VBox alignment="CENTER" spacing="12.0">
                    <StackPane minWidth="80" maxWidth="80" minHeight="80" maxHeight="80" style="-fx-background-color: #ffd6ee; -fx-background-radius: 40px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.25), 15, 0, 0, 4);">
                        <Label text="&#xe8d1;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 42px; -fx-text-fill: #e040a0;" />
                    </StackPane>
                    <Label text="TRỞ THÀNH NGƯỜI BÁN HÀNG" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2e1a28;" />
                    <Label text="Mở khóa các công cụ bán hàng chuyên nghiệp, tiếp cận hàng ngàn khách hàng tiềm năng và tăng trưởng doanh thu vượt bậc." wrapText="true" maxWidth="700" style="-fx-font-size: 16px; -fx-text-fill: #604868; -fx-text-alignment: center;" alignment="CENTER" />
                </VBox>

                <!-- 3 Benefits Cards -->
                <HBox alignment="CENTER" spacing="30.0" maxWidth="1000">
                    <!-- Card 1 -->
                    <VBox HBox.hgrow="ALWAYS" alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 30px 25px; -fx-background-radius: 24px; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.08), 20, 0, 0, 6);">
                        <StackPane minWidth="60" maxWidth="60" minHeight="60" maxHeight="60" style="-fx-background-color: #fef7ff; -fx-background-radius: 30px;">
                            <Label text="&#xe145;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 30px; -fx-text-fill: #e040a0;" />
                        </StackPane>
                        <Label text="Đăng bán dễ dàng" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2e1a28;" />
                        <Label text="Tạo phiên đấu giá nhanh chóng với các tùy chọn giá khởi điểm, bước giá và thời gian linh hoạt." wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #604868; -fx-text-alignment: center;" alignment="CENTER" />
                    </VBox>

                    <!-- Card 2 -->
                    <VBox HBox.hgrow="ALWAYS" alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 30px 25px; -fx-background-radius: 24px; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.08), 20, 0, 0, 6);">
                        <StackPane minWidth="60" maxWidth="60" minHeight="60" maxHeight="60" style="-fx-background-color: #fef7ff; -fx-background-radius: 30px;">
                            <Label text="&#xe8b8;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 30px; -fx-text-fill: #e040a0;" />
                        </StackPane>
                        <Label text="Quản lý chuyên nghiệp" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2e1a28;" />
                        <Label text="Theo dõi trực tiếp diễn biến các phiên đấu giá, quản lý người mua và đơn hàng hiệu quả." wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #604868; -fx-text-alignment: center;" alignment="CENTER" />
                    </VBox>

                    <!-- Card 3 -->
                    <VBox HBox.hgrow="ALWAYS" alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 30px 25px; -fx-background-radius: 24px; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.08), 20, 0, 0, 6);">
                        <StackPane minWidth="60" maxWidth="60" minHeight="60" maxHeight="60" style="-fx-background-color: #fef7ff; -fx-background-radius: 30px;">
                            <Label text="&#xe227;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 30px; -fx-text-fill: #e040a0;" />
                        </StackPane>
                        <Label text="Doanh thu vượt trội" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2e1a28;" />
                        <Label text="Tiếp cận cộng đồng người mua đông đảo trên HY Auction để đạt mức giá tốt nhất cho sản phẩm." wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #604868; -fx-text-alignment: center;" alignment="CENTER" />
                    </VBox>
                </HBox>

                <!-- Action / Form Card -->
                <VBox alignment="CENTER" spacing="20.0" maxWidth="600" style="-fx-background-color: #ffffff; -fx-padding: 35px 40px; -fx-background-radius: 24px; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.12), 25, 0, 0, 8);">
                    <CheckBox fx:id="chkAgree" text="Tôi đồng ý với các điều khoản và chính sách bán hàng của HY Auction." style="-fx-font-size: 15px; -fx-text-fill: #2e1a28; -fx-cursor: hand;" />
                    
                    <Label fx:id="lblMessage" text="" style="-fx-font-size: 14px;" visible="false" managed="false" />

                    <Button fx:id="btnUpgrade" onAction="#handleUpgrade" text="Nâng Cấp Ngay" prefWidth="300" prefHeight="50" style="-fx-background-color: #e040a0; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 25px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.4), 20, 0, 0, 6);">
                        <graphic><Label text="&#xe876;" translateY="2.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 24px; -fx-text-fill: white;" /></graphic>
                    </Button>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
