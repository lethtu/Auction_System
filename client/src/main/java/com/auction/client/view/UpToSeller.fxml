<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.paint.Color?>

<StackPane stylesheets="@styles.css" styleClass="rounded-window-root" style="-fx-font-family: 'DM Sans';" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.UpToSellerController">
<BorderPane prefWidth="1280.0" prefHeight="800.0" styleClass="rounded-window-content">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0.0" styleClass="app-topbar">
            <StackPane prefWidth="70.0" minWidth="70.0" maxWidth="70.0">
                <Button fx:id="btnHamburger" onAction="#handleToggleSidebar" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;">
                    <graphic>
                        <Label text="&#xe5d2;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; " />
                    </graphic>
                </Button>
            </StackPane>
            <Label text="HY Auction" textFill="#e040a0" onMouseClicked="#handleGoBack" style="-fx-cursor: hand;">
                <font>
                    <Font name="System Bold" size="28.0" />
                </font>
            </Label>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox alignment="CENTER_LEFT" prefWidth="500.0" prefHeight="40.0" style="  -fx-border-width: 2px; -fx-border-radius: 999; -fx-background-radius: 999; -fx-padding: 0 16px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.05), 10, 0, 0, 2);">
                <Label text="&#xe8b6;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #e040a0;" translateY="0.0" />
                <TextField fx:id="txtSearch" promptText="Search items, categories, or auctions..." HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-padding: 0 0 0 8px; -fx-prompt-text-fill: #907898;  -fx-font-size: 14px;" />
            </HBox>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox spacing="10.0" alignment="CENTER_RIGHT" minHeight="52.0" prefHeight="52.0" maxHeight="52.0" style="-fx-padding: 0;">
                <StackPane alignment="CENTER" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0">
                    <Button fx:id="btnNotificationBell" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center;">
                        <graphic>
                            <Label text="&#xe7f4;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; " />
                        </graphic>
                    </Button>
                    <Label fx:id="notificationBadge" text="0" visible="false" managed="false" style="-fx-background-color: #e040a0; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 1 5; -fx-background-radius: 10; -fx-translate-x: 12; -fx-translate-y: -12;" />
                </StackPane>
                <Button fx:id="btnSettings" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center;">
                    <graphic>
                        <Label text="&#xe8b8;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; " />
                    </graphic>
                </Button>
                <MenuButton fx:id="userMenuButton" id="profile-menu" minWidth="58.0" prefWidth="58.0" maxWidth="58.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center; -fx-background-insets: 0;">
                    <graphic>
                        <StackPane fx:id="topBarAvatarPane" minWidth="44" maxWidth="44" minHeight="44" maxHeight="44" prefWidth="44" prefHeight="44" style="-fx-background-color: #1a1a3a; -fx-background-radius: 22px;">
                            <Label text="&#xe7fd;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: white;" />
                        </StackPane>
                    </graphic>
                </MenuButton>
                <HBox alignment="CENTER" spacing="6" style="-fx-padding: 0 0 0 10;">
                    <Button onAction="#handleMinimize" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4;">
                        <graphic>
                            <Label text="−" style="-fx-font-family: 'DM Sans'; -fx-font-size: 16px; -fx-font-weight: 900; " />
                        </graphic>
                    </Button>
                    <Button onAction="#handleMaximize" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4;">
                        <graphic>
                            <Label text="□" style="-fx-font-family: 'DM Sans'; -fx-font-size: 16px; -fx-font-weight: 900; " />
                        </graphic>
                    </Button>
                    <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4;">
                        <graphic>
                            <Label text="×" style="-fx-font-family: 'DM Sans'; -fx-font-size: 16px; -fx-font-weight: 900; " />
                        </graphic>
                    </Button>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <left>
        <fx:include source="Sidebar.fxml" fx:id="sidebar">
            <BorderPane.margin>
                <Insets top="14.0" right="0.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
        </fx:include>
    </left>

    <center>
        <VBox spacing="20.0" styleClass="app-content-panel">
            <BorderPane.margin>
                <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
            <!-- Hero Banner / Title -->
            <VBox alignment="CENTER" spacing="12.0" style="-fx-padding: 0 0 10px 0;">
                <StackPane minWidth="80" maxWidth="80" minHeight="80" maxHeight="80" style="-fx-background-color: #ffd6ee; -fx-background-radius: 40px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.25), 15, 0, 0, 4);">
                    <Label text="&#xe8d1;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 42px; -fx-text-fill: #e040a0;" />
                </StackPane>
                <Label text="BECOME A SELLER" style="-fx-font-size: 36px; -fx-font-weight: bold; " />
                <Label text="Unlock professional selling tools, reach thousands of potential customers and achieve outstanding revenue growth." wrapText="true" maxWidth="700" style="-fx-font-size: 16px;  -fx-text-alignment: center;" alignment="CENTER" />
            </VBox>
            
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS" hbarPolicy="NEVER">
                <VBox alignment="CENTER" spacing="35.0" style="-fx-padding: 10px 0px;">

                <!-- 3 Benefits Cards -->
                <HBox alignment="CENTER" spacing="30.0" maxWidth="1000">
                    <!-- Card 1 -->
                    <VBox HBox.hgrow="ALWAYS" alignment="TOP_CENTER" spacing="15.0" style=" -fx-padding: 30px 25px; -fx-background-radius: 24px;  -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.08), 20, 0, 0, 6);">
                        <StackPane minWidth="60" maxWidth="60" minHeight="60" maxHeight="60" style="-fx-background-color: #fef7ff; -fx-background-radius: 30px;">
                            <Label text="&#xe145;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 30px; -fx-text-fill: #e040a0;" />
                        </StackPane>
                        <Label text="Easy Listing" style="-fx-font-size: 20px; -fx-font-weight: bold; " />
                        <Label text="Create auction sessions quickly with flexible starting price, step price and duration options." wrapText="true" style="-fx-font-size: 14px;  -fx-text-alignment: center;" alignment="CENTER" />
                    </VBox>

                    <!-- Card 2 -->
                    <VBox HBox.hgrow="ALWAYS" alignment="TOP_CENTER" spacing="15.0" style=" -fx-padding: 30px 25px; -fx-background-radius: 24px;  -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.08), 20, 0, 0, 6);">
                        <StackPane minWidth="60" maxWidth="60" minHeight="60" maxHeight="60" style="-fx-background-color: #fef7ff; -fx-background-radius: 30px;">
                            <Label text="&#xe8b8;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 30px; -fx-text-fill: #e040a0;" />
                        </StackPane>
                        <Label text="Professional Management" style="-fx-font-size: 20px; -fx-font-weight: bold; " />
                        <Label text="Monitor auction progress in real-time, manage buyers and orders effectively." wrapText="true" style="-fx-font-size: 14px;  -fx-text-alignment: center;" alignment="CENTER" />
                    </VBox>

                    <!-- Card 3 -->
                    <VBox HBox.hgrow="ALWAYS" alignment="TOP_CENTER" spacing="15.0" style=" -fx-padding: 30px 25px; -fx-background-radius: 24px;  -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.08), 20, 0, 0, 6);">
                        <StackPane minWidth="60" maxWidth="60" minHeight="60" maxHeight="60" style="-fx-background-color: #fef7ff; -fx-background-radius: 30px;">
                            <Label text="&#xe227;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 30px; -fx-text-fill: #e040a0;" />
                        </StackPane>
                        <Label text="Outstanding Revenue" style="-fx-font-size: 20px; -fx-font-weight: bold; " />
                        <Label text="Reach a large community of buyers on HY Auction to achieve the best price for your products." wrapText="true" style="-fx-font-size: 14px;  -fx-text-alignment: center;" alignment="CENTER" />
                    </VBox>
                </HBox>

                <!-- Action / Form Card -->
                <VBox alignment="CENTER" spacing="20.0" maxWidth="600" style=" -fx-padding: 35px 40px; -fx-background-radius: 24px;  -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.12), 25, 0, 0, 8);">
                    <CheckBox fx:id="chkAgree" text="I agree to the terms and seller policies of HY Auction." style="-fx-font-size: 15px;  -fx-cursor: hand;" />
                    
                    <Label fx:id="lblMessage" text="" style="-fx-font-size: 14px;" visible="false" managed="false" />

                    <Button fx:id="btnUpgrade" onAction="#handleUpgrade" text="Upgrade Now" prefWidth="300" prefHeight="50" style="-fx-background-color: #e040a0; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 25px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.4), 20, 0, 0, 6);">
                        <graphic><Label text="&#xe876;" translateY="2.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 24px; -fx-text-fill: white;" /></graphic>
                    </Button>
                </VBox>
                </VBox>
        </ScrollPane>
        </VBox>
    </center>
</BorderPane>
</StackPane>
