<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefWidth="1280.0" prefHeight="800.0" stylesheets="@styles.css" styleClass="rounded-window-root" style="-fx-font-family: 'DM Sans';" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.DepositController">
<BorderPane styleClass="rounded-window-content">

    <!-- Top Navigation Bar -->
    <top>
        <fx:include source="Topbar.fxml" fx:id="topbar"/>
    </top>

    <!-- Sidebar -->
    <left>
        <fx:include source="Sidebar.fxml" fx:id="sidebar">
            <BorderPane.margin>
                <Insets top="14.0" right="0.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
        </fx:include>
    </left>

    <!-- Main Content Canvas -->
    <center>
        <VBox spacing="20.0" styleClass="app-content-panel">
            <BorderPane.margin>
                <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
            <!-- Header -->
            <VBox spacing="8.0" style="-fx-padding: 0 0 10px 0;">
                <Label text="Deposit" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: -fx-accent;" />
                <Label text="Add funds to your wallet to continue bidding on your favorite items." style="-fx-font-size: 16px; -fx-text-fill: -app-text-muted;" />
            </VBox>
            
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="30.0" style="-fx-padding: 10px 0px;">

                <!-- Two Column Layout -->
                <HBox spacing="30.0" alignment="TOP_LEFT">
                    
                    <!-- Left Column: Top Up Form -->
                    <VBox spacing="30.0" prefWidth="700.0" HBox.hgrow="ALWAYS">
                        
                        <!-- Wallet Balance Card -->
                        <StackPane style="-fx-background-color: linear-gradient(to bottom right, -fx-accent, #7c52aa); -fx-background-radius: 20px; -fx-effect: dropshadow(three-pass-box, -app-accent-opacity-20, 30, 0, 0, 8); -fx-padding: 30px;">
                            <VBox spacing="15.0" alignment="CENTER_LEFT">
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <Label text="&#xe850;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 16px; -fx-text-fill: rgba(255, 255, 255, 0.8);" />
                                    <Label text="CURRENT WALLET BALANCE" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: rgba(255, 255, 255, 0.8);" />
                                </HBox>
                                <Label fx:id="lblWalletBalance" text="₫ 0" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: white;" />
                                <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-background-color: rgba(255, 255, 255, 0.2); -fx-padding: 6px 16px; -fx-background-radius: 999;">
                                    <StackPane style="-fx-background-color: #4ade80; -fx-background-radius: 5px; min-width: 10px; min-height: 10px; max-width: 10px; max-height: 10px;" />
                                    <Label text="Ready to bid" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;" />
                                </HBox>
                            </VBox>
                        </StackPane>

                        <!-- Select Amount -->
                        <VBox spacing="20.0" style="-fx-background-color: -app-card; -fx-background-radius: 20px; -fx-border-color: -app-border; -fx-border-width: 1.5px; -fx-border-radius: 20px; -fx-padding: 30px;">
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label text="&#xea1f;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 24px; -fx-text-fill: -fx-accent;" />
                                <Label text="Select Amount" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: -app-text;" />
                            </HBox>
                            
                            <!-- Quick Amounts Grid -->
                            <GridPane hgap="15.0" vgap="15.0">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="25.0" />
                                    <ColumnConstraints percentWidth="25.0" />
                                    <ColumnConstraints percentWidth="25.0" />
                                    <ColumnConstraints percentWidth="25.0" />
                                </columnConstraints>
                                <rowConstraints>
                                    <RowConstraints minHeight="60.0" />
                                </rowConstraints>
                                
                                <Button fx:id="btnAmount50" text="₫ 50.000" GridPane.columnIndex="0" maxWidth="Infinity" maxHeight="Infinity" onAction="#handleAmountSelection" style="-fx-background-color: -app-surface-2; -fx-text-fill: -app-text; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 12px; -fx-cursor: hand; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 12px;" />
                                <Button fx:id="btnAmount100" text="₫ 100.000" GridPane.columnIndex="1" maxWidth="Infinity" maxHeight="Infinity" onAction="#handleAmountSelection" style="-fx-background-color: -app-surface-2; -fx-text-fill: -app-text; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 12px; -fx-cursor: hand; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 12px;" />
                                <Button fx:id="btnAmount500" text="₫ 500.000" GridPane.columnIndex="2" maxWidth="Infinity" maxHeight="Infinity" onAction="#handleAmountSelection" style="-fx-background-color: -app-surface-2; -fx-text-fill: -app-text; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 12px; -fx-cursor: hand; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 12px;" />
                                <Button fx:id="btnAmount1000" text="₫ 1.000.000" GridPane.columnIndex="3" maxWidth="Infinity" maxHeight="Infinity" onAction="#handleAmountSelection" style="-fx-background-color: -app-surface-2; -fx-text-fill: -app-text; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 12px; -fx-cursor: hand; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 12px;" />
                            </GridPane>

                            <!-- Custom Amount -->
                            <StackPane alignment="CENTER_LEFT">
                                <TextField fx:id="txtCustomAmount" promptText="Enter a different amount..." style="-fx-background-color: -app-input-bg; -fx-border-color: -app-border; -fx-border-width: 1.5px; -fx-border-radius: 999; -fx-background-radius: 999; -fx-text-fill: -app-input-text; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 15px 20px 15px 45px; -fx-prompt-text-fill: -app-placeholder;" />
                                <Label text="₫" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: -app-text-muted; -fx-padding: 0 0 0 20px;" mouseTransparent="true" />
                            </StackPane>
                        </VBox>
                    </VBox>

                    <!-- Right Column: Summary Sticky -->
                    <VBox spacing="20.0" prefWidth="450.0" style="-fx-background-color: -app-card; -fx-background-radius: 20px; -fx-border-color: -app-border; -fx-border-width: 1.5px; -fx-border-radius: 20px; -fx-padding: 30px; -fx-effect: dropshadow(three-pass-box, rgba(46, 26, 40, 0.05), 40, 0, 0, 10);">
                        <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-padding: 0 0 15px 0; -fx-border-color: -app-border; -fx-border-width: 0 0 1px 0;">
                            <Label text="&#xe8b0;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 24px; -fx-text-fill: -app-text;" />
                            <Label text="Transaction Details" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: -app-text;" />
                        </HBox>

                        <VBox spacing="15.0">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Deposit amount" style="-fx-font-size: 16px; -fx-text-fill: -app-text-muted;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                <Label fx:id="lblSummaryAmount" text="₫ 0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -app-text;" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Transaction fee" style="-fx-font-size: 16px; -fx-text-fill: -app-text-muted;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                <Label text="Free (₫ 0)" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #10b981;" />
                            </HBox>
                            
                            <HBox alignment="CENTER_LEFT" style="-fx-padding: 15px 0 0 0; -fx-border-color: -app-border; -fx-border-width: 1px 0 0 0;">
                                <Label text="Total" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -app-text;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                <Label fx:id="lblSummaryTotal" text="₫ 0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: -fx-accent;" />
                            </HBox>
                        </VBox>

                        <Button fx:id="btnConfirmDeposit" text="&#8594; Confirm Deposit" onAction="#handleConfirmDeposit" maxWidth="Infinity" style="-fx-background-color: -fx-accent; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 999; -fx-padding: 15px; -fx-cursor: hand; -fx-alignment: center; -fx-text-alignment: center; -fx-effect: dropshadow(three-pass-box, -app-accent-opacity-30, 16, 0, 0, 4);" />

                        <Label text="By confirming, you agree to our Terms of Service." wrapText="true" textAlignment="CENTER" alignment="CENTER" maxWidth="Infinity" style="-fx-font-size: 12px; -fx-text-fill: -app-text-muted;" />
                    </VBox>

                </HBox>
            </VBox>
        </ScrollPane>
        </VBox>
    </center>

</BorderPane>
    <VBox fx:id="toastContainer" pickOnBounds="false" alignment="BOTTOM_RIGHT" spacing="10" style="-fx-padding: 30px;" />
</StackPane>
