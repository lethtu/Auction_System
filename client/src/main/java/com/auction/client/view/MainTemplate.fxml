<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>

<?import javafx.scene.control.*?>

<?import javafx.scene.layout.*?>

<?import javafx.scene.text.Font?>

<?import javafx.scene.paint.Color?>

<StackPane prefWidth="1280.0" prefHeight="700.0" stylesheets="@styles.css" styleClass="rounded-window-root" style="-fx-font-family: 'DM Sans';" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.MainController">
<BorderPane styleClass="rounded-window-content">



    <top>
        <fx:include source="Topbar.fxml" fx:id="topbar"/>
    </top>



    <left>
        <fx:include source="Sidebar.fxml" fx:id="sidebar">
            <BorderPane.margin>
                <Insets top="14.0" right="0.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
        </fx:include>
    </left>



    <center>
        <VBox spacing="20.0" styleClass="app-content-panel">
            <BorderPane.margin>
                <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
            <!-- Header Section inside Center -->
            <HBox fx:id="mainPageHeader" alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 0 0 0 0;">
                <Label fx:id="lblPageTitle" id="mainPageTitle" text="Live Auctions" style="-fx-text-fill: -fx-accent; -fx-font-weight: 900; -fx-font-size: 32px;">

                    <font>

                        <Font name="System Bold" size="28.0" />

                    </font>

                </Label>



                <Region HBox.hgrow="ALWAYS" />



                <!-- Filter controls mapping to cbCategory and cbStatus -->
                <HBox fx:id="filterControlsBox" spacing="12.0" alignment="CENTER_RIGHT" styleClass="filter-controls-bar">

                    <Label text="Filter:" textFill="#604868" styleClass="filter-label" />

                    <ComboBox fx:id="cbCategory" promptText="Category" prefWidth="150.0" styleClass="filter-combo" />

                    <ComboBox fx:id="cbStatus" promptText="Status" prefWidth="150.0" styleClass="filter-combo" />

                    <Button fx:id="btnToggleProductView"
                            mnemonicParsing="false"
                            onAction="#handleToggleProductView"
                            alignment="CENTER"
                            contentDisplay="GRAPHIC_ONLY"
                            styleClass="view-toggle-button">
                        <graphic>
                            <GridPane fx:id="btnToggleProductViewIcon"
                                      alignment="CENTER"
                                      hgap="3"
                                      vgap="3"
                                      styleClass="view-toggle-grid-icon">
                                <Region prefWidth="7" prefHeight="7" minWidth="7" minHeight="7" maxWidth="7" maxHeight="7" styleClass="view-toggle-tile" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <Region prefWidth="7" prefHeight="7" minWidth="7" minHeight="7" maxWidth="7" maxHeight="7" styleClass="view-toggle-tile" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <Region prefWidth="7" prefHeight="7" minWidth="7" minHeight="7" maxWidth="7" maxHeight="7" styleClass="view-toggle-tile" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <Region prefWidth="7" prefHeight="7" minWidth="7" minHeight="7" maxWidth="7" maxHeight="7" styleClass="view-toggle-tile" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            </GridPane>
                        </graphic>
                    </Button>
                </HBox>

            </HBox>



            <ScrollPane fx:id="scrollPane"
                        fitToWidth="true"
                        fitToHeight="true"
                        hbarPolicy="NEVER"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <StackPane fx:id="productViewport" alignment="TOP_LEFT" style="-fx-background-color: transparent;">
                    <FlowPane fx:id="productContainer"
                              alignment="TOP_LEFT"
                              hgap="25.0"
                              vgap="25.0"
                              style="-fx-padding: 10px 12px 24px 12px;">
                    </FlowPane>
                </StackPane>
            </ScrollPane>
            </VBox>

    </center>



</BorderPane>

    <VBox fx:id="toastContainer" pickOnBounds="false" alignment="BOTTOM_RIGHT" spacing="10" style="-fx-padding: 30px;" />

</StackPane>
