<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.paint.Color?>

<StackPane prefWidth="1280.0" prefHeight="700.0" stylesheets="@styles.css" styleClass="rounded-window-root" style="-fx-font-family: 'DM Sans';" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.MainController">
<BorderPane styleClass="rounded-window-content">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0.0" styleClass="app-topbar">
            <StackPane prefWidth="70.0" minWidth="70.0" maxWidth="70.0">
                <Button fx:id="btnHamburger" onAction="#handleToggleSidebar" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;">
                    <graphic>
                        <Label text="&#xe5d2;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" />
                    </graphic>
                </Button>
            </StackPane>
            <Button onAction="#handleResetDashboard" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-border-color: transparent; -fx-font-family: 'System'; -fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e040a0;" text="HY Auction" />
            
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox alignment="CENTER_LEFT" prefWidth="500.0" prefHeight="40.0" style="-fx-background-color: #ffffff; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 999; -fx-background-radius: 999; -fx-padding: 0 16px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.05), 10, 0, 0, 2);">
                <Label text="&#xe8b6;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #e040a0;" translateY="0.0" />
                <TextField fx:id="txtSearch" promptText="Search items, categories, or auctions..." HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-padding: 0 0 0 8px; -fx-prompt-text-fill: #907898; -fx-text-fill: #2e1a28; -fx-font-size: 14px;" />
            </HBox>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox spacing="10.0" alignment="CENTER_RIGHT" minHeight="52.0" prefHeight="52.0" maxHeight="52.0" style="-fx-padding: 0;">
                <StackPane alignment="CENTER" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0">
                    <Button fx:id="btnNotificationBell" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center;">
                        <graphic>
                            <Label text="&#xe7f4;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" />
                        </graphic>
                    </Button>
                    <Label fx:id="notificationBadge" text="0" visible="false" managed="false" style="-fx-background-color: #e040a0; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 1 5; -fx-background-radius: 10; -fx-translate-x: 12; -fx-translate-y: -12;" />
                </StackPane>
                <Button onAction="#handleSettings" minWidth="44.0" prefWidth="44.0" maxWidth="44.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center;">
                    <graphic>
                        <Label text="&#xe8b8;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" />
                    </graphic>
                </Button>
                <MenuButton fx:id="userMenuButton" id="profile-menu" minWidth="58.0" prefWidth="58.0" maxWidth="58.0" minHeight="44.0" prefHeight="44.0" maxHeight="44.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0; -fx-alignment: center; -fx-background-insets: 0;">
                    <graphic>
                        <StackPane fx:id="topBarAvatarPane" minWidth="44" maxWidth="44" minHeight="44" maxHeight="44" prefWidth="44" prefHeight="44" style="-fx-background-color: #1a1a3a; -fx-background-radius: 22px;">
                            <Label text="&#xe7fd;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: white;" />
                        </StackPane>
                    </graphic>
                </MenuButton>
                
                <HBox alignment="CENTER" spacing="6" style="-fx-padding: 0 0 0 10;">
                    <Button onAction="#handleMinimize" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4;">
                        <graphic>
                            <Label text="−" style="-fx-font-family: 'DM Sans'; -fx-font-size: 16px; -fx-font-weight: 900; -fx-text-fill: #907898;" />
                        </graphic>
                    </Button>
                    <Button onAction="#handleMaximize" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4;">
                        <graphic>
                            <Label text="□" style="-fx-font-family: 'DM Sans'; -fx-font-size: 16px; -fx-font-weight: 900; -fx-text-fill: #907898;" />
                        </graphic>
                    </Button>
                    <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4;">
                        <graphic>
                            <Label text="×" style="-fx-font-family: 'DM Sans'; -fx-font-size: 16px; -fx-font-weight: 900; -fx-text-fill: #907898;" />
                        </graphic>
                    </Button>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <left>
        <fx:include source="Sidebar.fxml" fx:id="sidebar" />
    </left>

    <center>
        <VBox spacing="20.0" styleClass="app-content-panel">
            <BorderPane.margin>
                <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
            <!-- Header Section inside Center -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 0 0 0 0;">
                <Label fx:id="lblPageTitle" text="Live Auctions" textFill="#2e1a28">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
                
                <Region HBox.hgrow="ALWAYS" />
                
                <!-- Filter controls mapping to cbCategory and cbStatus -->
                <HBox fx:id="filterControlsBox" spacing="10.0" alignment="CENTER">
                    <Label text="Filter:" textFill="#604868" style="-fx-font-weight: bold;" />
                    <ComboBox fx:id="cbCategory" promptText="Category" prefWidth="150.0" style="-fx-background-color: #fef7ff; -fx-border-color: #ffe8e8; -fx-border-radius: 32px; -fx-background-radius: 32px; -fx-text-fill: #e040a0;" />
                    <ComboBox fx:id="cbStatus" promptText="Status" prefWidth="150.0" style="-fx-background-color: #fef7ff; -fx-border-color: #ffe8e8; -fx-border-radius: 32px; -fx-background-radius: 32px; -fx-text-fill: #e040a0;" />
                    <Button fx:id="btnResetFilter" onAction="#handleResetFilter" text="Reset" graphicTextGap="5.0" style="-fx-background-color: #ffffff; -fx-border-color: #f2e8f2; -fx-border-radius: 999; -fx-background-radius: 999; -fx-text-fill: #604868; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 6px 14px;">
                        <graphic><Label text="&#xe9b0;" translateY="2.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #e040a0;" /></graphic>
                    </Button>
                    <Button onAction="#handleListView" style="-fx-background-color: #ffffff; -fx-border-color: #f2e8f2; -fx-border-radius: 999; -fx-background-radius: 999; -fx-cursor: hand; -fx-padding: 6px 8px;">
                        <graphic><Label text="&#xe8ef;" translateY="2.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #907898;" /></graphic>
                    </Button>
                </HBox>
            </HBox>
            
            <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <FlowPane fx:id="productContainer" alignment="TOP_LEFT" hgap="25.0" vgap="25.0" style="-fx-padding: 10px 2px;">
                </FlowPane>
            </ScrollPane>
        </VBox>
    </center>
    
</BorderPane>
    <VBox fx:id="toastContainer" pickOnBounds="false" alignment="BOTTOM_RIGHT" spacing="10" style="-fx-padding: 30px;" />
</StackPane>
