<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.paint.Color?>

<BorderPane prefWidth="1280.0" prefHeight="700.0" stylesheets="@styles.css" style="-fx-background-color: #fef7ff; -fx-font-family: 'DM Sans';" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.MainController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: rgba(254, 247, 255, 0.9); -fx-padding: 12px 30px; -fx-border-color: #ffe8e8; -fx-border-width: 0 0 2px 0; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.15), 20, 0, 0, 4);">
            <Button fx:id="btnHamburger" onAction="#handleToggleSidebar" style="-fx-background-color: transparent; -fx-cursor: hand;">
                <graphic>
                    <Label text="&#xe5d2;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" />
                </graphic>
            </Button>
            <Label text="HY Auction" textFill="#e040a0" style="-fx-cursor: hand;">
                <font>
                    <Font name="System Bold" size="28.0" />
                </font>
            </Label>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox alignment="CENTER_LEFT" prefWidth="500.0" prefHeight="40.0" style="-fx-background-color: #ffffff; -fx-border-color: #ffe8e8; -fx-border-width: 2px; -fx-border-radius: 999; -fx-background-radius: 999; -fx-padding: 0 16px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.05), 10, 0, 0, 2);">
                <Label text="&#xe8b6;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: #e040a0;" translateY="3.0" />
                <TextField fx:id="txtSearch" promptText="Search items, categories, or auctions..." HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-padding: 0 0 0 8px; -fx-prompt-text-fill: #907898; -fx-text-fill: #2e1a28; -fx-font-size: 14px;" />
            </HBox>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox spacing="15.0" alignment="CENTER_RIGHT">
                <Button onAction="#handleNotifications" style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <graphic>
                        <Label text="&#xe7f4;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" />
                    </graphic>
                </Button>
                <Button onAction="#handleSettings" style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <graphic>
                        <Label text="&#xe8b8;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #604868;" />
                    </graphic>
                </Button>
                <MenuButton fx:id="userMenuButton" id="profile-menu" style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <graphic>
                        <StackPane minWidth="36" maxWidth="36" minHeight="36" maxHeight="36" prefWidth="36" prefHeight="36" style="-fx-background-color: #1a1a3a; -fx-background-radius: 18px;">
                            <Label text="&#xe7fd;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: white;" />
                        </StackPane>
                    </graphic>
                </MenuButton>
                <Button fx:id="btnDashboard" onAction="#handleGoToDashboard" text="Kênh Người Bán" visible="false" managed="false" />
            </HBox>
        </HBox>
    </top>

    <left>
        <fx:include source="Sidebar.fxml" fx:id="sidebar" />
    </left>

    <center>
        <VBox spacing="20.0" style="-fx-background-color: transparent;">
            <!-- Header Section inside Center -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 24px 24px 0 24px;">
                <Label text="Live Auctions" textFill="#2e1a28">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
                
                <Region HBox.hgrow="ALWAYS" />
                
                <!-- Filter controls mapping to cbCategory and cbStatus -->
                <HBox spacing="10.0" alignment="CENTER">
                    <Label text="Lọc:" textFill="#604868" style="-fx-font-weight: bold;" />
                    <ComboBox fx:id="cbCategory" promptText="Thể loại" prefWidth="150.0" style="-fx-background-color: #fef7ff; -fx-border-color: #ffe8e8; -fx-border-radius: 32px; -fx-background-radius: 32px; -fx-text-fill: #e040a0;" />
                    <ComboBox fx:id="cbStatus" promptText="Trạng thái" prefWidth="150.0" style="-fx-background-color: #fef7ff; -fx-border-color: #ffe8e8; -fx-border-radius: 32px; -fx-background-radius: 32px; -fx-text-fill: #e040a0;" />
                    <Button fx:id="btnResetFilter" onAction="#handleResetFilter" text="Đặt lại" graphicTextGap="5.0" style="-fx-background-color: #ffffff; -fx-border-color: #f2e8f2; -fx-border-radius: 999; -fx-background-radius: 999; -fx-text-fill: #604868; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 6px 14px;">
                        <graphic><Label text="&#xe9b0;" translateY="2.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #e040a0;" /></graphic>
                    </Button>
                    <Button onAction="#handleListView" style="-fx-background-color: #ffffff; -fx-border-color: #f2e8f2; -fx-border-radius: 999; -fx-background-radius: 999; -fx-cursor: hand; -fx-padding: 6px 8px;">
                        <graphic><Label text="&#xe8ef;" translateY="2.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: #907898;" /></graphic>
                    </Button>
                </HBox>
            </HBox>
            
            <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <FlowPane fx:id="productContainer" alignment="TOP_LEFT" hgap="25.0" vgap="25.0" style="-fx-padding: 10px 2px;">
                </FlowPane>
            </ScrollPane>
        </VBox>
    </center>
    
</BorderPane>