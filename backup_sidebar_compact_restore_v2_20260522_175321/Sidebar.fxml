<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fx:id="sidebarContainer" fitToWidth="true" hbarPolicy="NEVER" styleClass="app-sidebar-scroll" minWidth="214.0" prefWidth="214.0" maxWidth="214.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.SidebarController">
    <VBox fx:id="sidebarContent" spacing="8.0" styleClass="app-sidebar-content">
        <!-- Main Menu -->
        <Label text="MAIN MENU" style="-fx-text-fill: #907898; -fx-font-family: 'DM Sans'; -fx-font-size: 11px; -fx-font-weight: 800; -fx-padding: 2px 0 8px 18px;" />
        <Button fx:id="btnSidebarDashboard" onAction="#handleDashboard" text="Dashboard" alignment="CENTER_LEFT" prefWidth="184.0" minWidth="184.0" maxWidth="184.0" prefHeight="46.0" minHeight="46.0" maxHeight="46.0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 15px; -fx-background-color: rgba(224, 64, 160, 0.16); -fx-text-fill: #e040a0; -fx-font-weight: 800; -fx-background-radius: 23px; -fx-padding: 10px 18px; -fx-cursor: hand;">
            <graphic><Label text="&#xe871;" minWidth="26.0" minHeight="26.0" alignment="CENTER" translateY="2.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 21px; -fx-font-weight: normal; -fx-text-fill: #e040a0;" /></graphic>
        </Button>
        <Button fx:id="btnMyBids" onAction="#handleMyBids" text="My Bids" alignment="CENTER_LEFT" prefWidth="184.0" minWidth="184.0" maxWidth="184.0" prefHeight="46.0" minHeight="46.0" maxHeight="46.0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 15px; -fx-background-color: transparent; -fx-text-fill: #604868; -fx-font-weight: 800; -fx-background-radius: 23px; -fx-padding: 10px 18px; -fx-cursor: hand;">
            <graphic><Label text="&#xe90e;" minWidth="26.0" minHeight="26.0" alignment="CENTER" translateY="2.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 21px; -fx-font-weight: normal; -fx-text-fill: #604868;" /></graphic>
        </Button>
        <Button fx:id="btnSelling" onAction="#handleSelling" text="Selling" alignment="CENTER_LEFT" prefWidth="184.0" minWidth="184.0" maxWidth="184.0" prefHeight="46.0" minHeight="46.0" maxHeight="46.0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 15px; -fx-background-color: transparent; -fx-text-fill: #604868; -fx-font-weight: 800; -fx-background-radius: 23px; -fx-padding: 10px 18px; -fx-cursor: hand;">
            <graphic><Label text="&#xea12;" minWidth="26.0" minHeight="26.0" alignment="CENTER" translateY="2.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 21px; -fx-font-weight: normal; -fx-text-fill: #604868;" /></graphic>
        </Button>

        <Button fx:id="btnSidebarWatchlist" onAction="#handleWatchlist" text="Watchlist" alignment="CENTER_LEFT" prefWidth="184.0" minWidth="184.0" maxWidth="184.0" prefHeight="46.0" minHeight="46.0" maxHeight="46.0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 15px; -fx-background-color: transparent; -fx-text-fill: #604868; -fx-font-weight: 800; -fx-background-radius: 23px; -fx-padding: 10px 18px; -fx-cursor: hand;">
            <graphic><Label text="&#xe8f4;" minWidth="26.0" minHeight="26.0" alignment="CENTER" translateY="2.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 21px; -fx-font-weight: normal; -fx-text-fill: #604868;" /></graphic>
        </Button>
        
        <Button fx:id="btnSupport" onAction="#handleSupport" text="Support" alignment="CENTER_LEFT" prefWidth="184.0" minWidth="184.0" maxWidth="184.0" prefHeight="46.0" minHeight="46.0" maxHeight="46.0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 15px; -fx-background-color: transparent; -fx-text-fill: #604868; -fx-font-weight: 800; -fx-background-radius: 23px; -fx-padding: 10px 18px; -fx-cursor: hand;">
            <graphic><Label text="&#xe887;" minWidth="26.0" minHeight="26.0" alignment="CENTER" translateY="2.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 21px; -fx-font-weight: normal; -fx-text-fill: #604868;" /></graphic>
        </Button>
        <Region prefHeight="8.0" />

        <!-- Start Selling Button -->
        <Button fx:id="btnStartSelling" onAction="#handleStartSelling" text="Start Selling" prefWidth="184.0" minWidth="184.0" maxWidth="184.0" prefHeight="46.0" minHeight="46.0" maxHeight="46.0" style="-fx-font-family: 'DM Sans'; -fx-font-size: 15px; -fx-background-color: #e040a0; -fx-text-fill: white; -fx-font-weight: 800; -fx-background-radius: 23px; -fx-padding: 0 14px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.30), 16, 0, 0, 4);">
            <graphic><Label text="&#xe145;" minWidth="24.0" minHeight="24.0" alignment="CENTER" translateY="3.0" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-font-weight: normal; -fx-text-fill: white;" /></graphic>
        </Button>

        <Region VBox.vgrow="ALWAYS" />
    </VBox>
</ScrollPane>
