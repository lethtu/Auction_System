<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefWidth="1280.0" prefHeight="800.0" stylesheets="@styles.css" styleClass="rounded-window-root" style="-fx-font-family: 'DM Sans';" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.SettingsController">
<BorderPane styleClass="rounded-window-content">

    <top>
        <fx:include source="Topbar.fxml" fx:id="topbar"/>
    </top>

    <left>
        <fx:include source="Sidebar.fxml" fx:id="sidebar">
            <BorderPane.margin>
                <Insets top="14.0" right="0.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
        </fx:include>
    </left>

    <center>
        <VBox spacing="20.0" styleClass="app-content-panel">
            <BorderPane.margin>
                <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
            </BorderPane.margin>
            <VBox spacing="10.0" style="-fx-padding: 0 0 10px 0;">
                <Label text="CONFIGURATION &amp; SYSTEM SETTINGS" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: -fx-accent;" />
                <Label text="Customize notifications, sounds, interface and your auction experience." style="-fx-font-size: 15px; -fx-text-fill: -app-text-muted;" />
            </VBox>
            
            <ScrollPane styleClass="settings-scroll-pane" fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="35.0" style="-fx-padding: 10px 0px;">

                    <VBox fx:id="passwordSetBox" spacing="16.0" style="-fx-background-color: #fff9e6; -fx-padding: 24px 30px; -fx-background-radius: 20px; -fx-border-color: #ffe0b2; -fx-border-width: 2px; -fx-border-radius: 20px; -fx-effect: dropshadow(three-pass-box, rgba(255, 152, 0, 0.05), 15, 0, 0, 4);">
                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <Label text="&#xe8a6;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 24px; -fx-text-fill: #e65100;" />
                            <Label text="SET ACCOUNT PASSWORD" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e65100;" />
                        </HBox>
                        <Label text="This Google account does not have a local password yet. Set one below if you want to sign in later with your email or username." wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #5d4037; -fx-line-spacing: 4px;" />
                        <HBox spacing="20.0" alignment="CENTER_LEFT">
                            <PasswordField fx:id="txtNewPassword" promptText="New password (min 6 characters)" prefWidth="250.0" style="-fx-background-color: -app-card; -fx-border-color: #ffe0b2; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 10px; -fx-font-size: 14px;" />
                            <PasswordField fx:id="txtConfirmPassword" promptText="Confirm new password" prefWidth="250.0" style="-fx-background-color: -app-card; -fx-border-color: #ffe0b2; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 10px; -fx-font-size: 14px;" />
                            <Button fx:id="btnSetPassword" onAction="#handleSetPassword" text="Set Password" prefHeight="40.0" style="-fx-background-color: #e65100; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-cursor: hand; -fx-padding: 8px 24px;" />
                        </HBox>
                    </VBox>

                    <VBox fx:id="passwordChangeBox" spacing="16.0" style="-fx-background-color: -app-card; -fx-padding: 24px 30px; -fx-background-radius: 20px; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 20px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.05), 15, 0, 0, 4);">
                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <Label text="&#xe8a6;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 24px; -fx-text-fill: -fx-accent;" />
                            <Label text="CHANGE PASSWORD" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -fx-accent;" />
                        </HBox>
                        <Label text="Update your account password to keep your account secure. Enter your current password before saving the new one." wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: -app-text-muted; -fx-line-spacing: 4px;" />
                        <HBox spacing="20.0" alignment="CENTER_LEFT">
                            <PasswordField fx:id="txtOldPassword" promptText="Current password" prefWidth="220.0" style="-fx-background-color: -app-card; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 10px; -fx-font-size: 14px;" />
                            <PasswordField fx:id="txtChangeNewPassword" promptText="New password (min 6 chars)" prefWidth="220.0" style="-fx-background-color: -app-card; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 10px; -fx-font-size: 14px;" />
                            <PasswordField fx:id="txtChangeConfirmPassword" promptText="Confirm new password" prefWidth="220.0" style="-fx-background-color: -app-card; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 10px; -fx-font-size: 14px;" />
                            <Button fx:id="btnChangePassword" onAction="#handleChangePassword" text="Change Password" prefHeight="40.0" minWidth="150.0" style="-fx-background-color: -fx-accent; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-cursor: hand; -fx-padding: 8px 24px;" />
                        </HBox>
                    </VBox>

                    <HBox spacing="40.0" alignment="TOP_LEFT">
                        <VBox spacing="24.0" prefWidth="560.0" minWidth="460.0" HBox.hgrow="ALWAYS" style="-fx-background-color: -app-card; -fx-padding: 30px; -fx-background-radius: 24px; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.06), 20, 0, 0, 6);">
                            <Label text="APP CONFIGURATION" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-accent;" />
                            
                            <VBox spacing="12.0">
                                <Label text="NOTIFICATIONS" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: -fx-accent; -fx-padding: 0 0 4px 0;" />
                                <CheckBox fx:id="chkNotificationsEnabled" text="Enable in-app notifications" style="-fx-font-size: 14px; -fx-text-fill: -app-text; -fx-cursor: hand;" />
                                <CheckBox fx:id="chkOutbid" text="Notify me when I am outbid" style="-fx-font-size: 14px; -fx-text-fill: -app-text; -fx-cursor: hand;" />
                                <CheckBox fx:id="chkEndingSoon" text="Notify me when an auction is ending soon" style="-fx-font-size: 14px; -fx-text-fill: -app-text; -fx-cursor: hand;" />
                                <CheckBox fx:id="chkAuctionResult" text="Notify me about auction results" style="-fx-font-size: 14px; -fx-text-fill: -app-text; -fx-cursor: hand;" />
                            </VBox>

                            <Separator style="-fx-background-color: -app-border; -fx-opacity: 0.5;" />

                            <VBox spacing="14.0">
                                <Label text="SOUNDS" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: -fx-accent; -fx-padding: 0 0 4px 0;" />
                                <CheckBox fx:id="chkSound" text="Play notification sounds" style="-fx-font-size: 14px; -fx-text-fill: -app-text; -fx-cursor: hand;" />
                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <Label text="Volume:" style="-fx-font-size: 14px; -fx-text-fill: -app-text;" />
                                    <Slider fx:id="sliderVolume" min="0.0" max="100.0" value="60.0" prefWidth="220.0" />
                                    <Label fx:id="lblVolumeValue" text="60%" minWidth="45.0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -app-text-muted;" />
                                    <Button onAction="#handleTestSound" text="Test Sound" prefHeight="36.0" style="-fx-background-color: -app-surface-2; -fx-text-fill: -fx-accent; -fx-font-weight: bold; -fx-background-radius: 10px; -fx-border-color: -app-border; -fx-border-radius: 10px; -fx-padding: 7px 18px; -fx-cursor: hand;" />
                                </HBox>
                            </VBox>

                            <Separator style="-fx-background-color: -app-border; -fx-opacity: 0.5;" />

                            <VBox spacing="16.0">
                                <Label text="INTERFACE &amp; EXPERIENCE" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: -fx-accent; -fx-padding: 0 0 4px 0;" />
                                <CheckBox fx:id="chkCollapse" text="Auto-collapse sidebar" style="-fx-font-size: 14px; -fx-text-fill: -app-text; -fx-cursor: hand;" />
                                <CheckBox fx:id="chkRememberPage" text="Remember last visited page" style="-fx-font-size: 14px; -fx-text-fill: -app-text; -fx-cursor: hand;" />

                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <Label text="App language:" style="-fx-font-size: 14px; -fx-text-fill: -app-text;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <ComboBox fx:id="cbLang" prefWidth="180.0" style="-fx-background-color: -app-card; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-cursor: hand;" />
                                </HBox>
                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <Label text="Theme:" style="-fx-font-size: 14px; -fx-text-fill: -app-text;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <ComboBox fx:id="cbTheme" prefWidth="180.0" style="-fx-background-color: -app-input-bg; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-cursor: hand;" />
                                </HBox>
                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <Label text="Accent color:" style="-fx-font-size: 14px; -fx-text-fill: -app-text;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <ComboBox fx:id="cbColor" prefWidth="180.0" style="-fx-background-color: -app-input-bg; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-cursor: hand;" />
                                </HBox>
                            </VBox>

                            <Label fx:id="lblStatus" text="" visible="false" managed="false" style="-fx-font-size: 14px; -fx-font-weight: bold;" />

                            <Button fx:id="btnSaveSettings" onAction="#handleSaveSettings" text="Save Settings" maxWidth="Infinity" prefHeight="48.0" style="-fx-background-color: -fx-accent; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 24px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.3), 12, 0, 0, 4);">
                                <graphic>
                                    <Label text="&#xe876;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: white;" translateY="2.0" />
                                </graphic>
                            </Button>
                        </VBox>

                        <VBox spacing="24.0" HBox.hgrow="ALWAYS">
                            <VBox spacing="18.0" style="-fx-background-color: -app-card; -fx-padding: 30px; -fx-background-radius: 24px; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.06), 20, 0, 0, 6);">
                                <Label text="AUCTION PREFERENCES" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-accent;" />
                                <CheckBox fx:id="chkConfirmBid" text="Confirm before placing a bid" style="-fx-font-size: 14px; -fx-text-fill: -app-text; -fx-cursor: hand;" />
                                <CheckBox fx:id="chkQuickBid" text="Enable quick bid shortcuts" style="-fx-font-size: 14px; -fx-text-fill: -app-text; -fx-cursor: hand;" />
                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <Label text="High-bid warning at:" style="-fx-font-size: 14px; -fx-text-fill: -app-text;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <TextField fx:id="txtHighBidWarning" prefWidth="160.0" promptText="1000000" style="-fx-background-color: -app-card; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 8px;" />
                                </HBox>
                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <Label text="Default bid increment:" style="-fx-font-size: 14px; -fx-text-fill: -app-text;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <TextField fx:id="txtDefaultIncrement" prefWidth="160.0" promptText="10000" style="-fx-background-color: -app-card; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 8px;" />
                                </HBox>
                            </VBox>

                            <VBox spacing="18.0" style="-fx-background-color: -app-card; -fx-padding: 30px; -fx-background-radius: 24px; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.06), 20, 0, 0, 6);">
                                <Label text="DASHBOARD DISPLAY" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-accent;" />
                                <CheckBox fx:id="chkShowEnded" text="Show ended auctions" style="-fx-font-size: 14px; -fx-text-fill: -app-text; -fx-cursor: hand;" />
                                <CheckBox fx:id="chkSortActive" text="Sort active auctions first" style="-fx-font-size: 14px; -fx-text-fill: -app-text; -fx-cursor: hand;" />
                                <CheckBox fx:id="chkShowCountdown" text="Show countdown timers" style="-fx-font-size: 14px; -fx-text-fill: -app-text; -fx-cursor: hand;" />
                                <CheckBox fx:id="chkCompactCards" text="Use compact auction cards" style="-fx-font-size: 14px; -fx-text-fill: -app-text; -fx-cursor: hand;" />
                            </VBox>

                            <VBox spacing="20.0" style="-fx-background-color: -app-card; -fx-padding: 30px; -fx-background-radius: 24px; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.06), 20, 0, 0, 6);">
                                <Label text="QUICK ACTIONS" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-accent;" />
                                <Label text="Shortcuts for resetting filters and requesting a fresh data reload." wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: -app-text-muted;" />
                                <HBox spacing="15.0">
                                    <Button fx:id="btnResetFilters" onAction="#handleResetFilters" text="Reset Filters" prefHeight="40.0" style="-fx-background-color: -app-surface-2; -fx-text-fill: -fx-accent; -fx-font-weight: bold; -fx-background-radius: 10px; -fx-border-color: -app-border; -fx-border-radius: 10px; -fx-padding: 8px 20px; -fx-cursor: hand;" />
                                    <Button fx:id="btnReloadData" onAction="#handleReloadData" text="Reload Data" prefHeight="40.0" style="-fx-background-color: -app-surface-2; -fx-text-fill: -fx-accent; -fx-font-weight: bold; -fx-background-radius: 10px; -fx-border-color: -app-border; -fx-border-radius: 10px; -fx-padding: 8px 20px; -fx-cursor: hand;" />
                                </HBox>
                            </VBox>

                            <VBox spacing="16.0" style="-fx-background-color: -app-card; -fx-padding: 30px; -fx-background-radius: 24px; -fx-border-color: -app-border; -fx-border-width: 2px; -fx-border-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(224, 64, 160, 0.06), 20, 0, 0, 6);">
                                <Label text="SYSTEM INFORMATION" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-accent;" />
                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <Label text="&#xe8d4;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: -fx-accent;" />
                                    <Label text="App version: 0.1 (Stable)" style="-fx-font-size: 14px; -fx-text-fill: -app-text; -fx-font-weight: bold;" />
                                </HBox>
                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <Label text="&#xe1b1;" style="-fx-font-family: 'Material Symbols Outlined'; -fx-font-size: 20px; -fx-text-fill: -fx-accent;" />
                                    <Label text="Server status: Connected" style="-fx-font-size: 14px; -fx-text-fill: -app-text; -fx-font-weight: bold;" />
                                </HBox>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
    <VBox fx:id="toastContainer" pickOnBounds="false" alignment="BOTTOM_RIGHT" spacing="10" style="-fx-padding: 30px;" />
</StackPane>

